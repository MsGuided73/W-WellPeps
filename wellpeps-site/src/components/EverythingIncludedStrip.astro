---
/**
 * "Everything Included" strip — client-approved design (Claude Design:
 * Everything Included Strip.dc.html). A warm-ivory band with a serif
 * headline block and seven included-item columns. Mounted at the bottom
 * of each treatment area's product section.
 */
const items = [
  { label: 'Prescription Medication', src: '/images/icons/included/meds.png' },
  { label: 'Licensed Provider Evaluation', src: '/images/icons/included/provider.png' },
  { label: 'Ongoing Support', src: '/images/icons/included/support.png' },
  { label: 'Standard Shipping', src: '/images/icons/included/truck.png' },
  { label: 'No Membership Fees', src: '/images/icons/included/nofee.png' },
  { label: 'No Hidden Fees', src: '/images/icons/included/tag.png' },
  { label: 'Cancel Anytime*', src: '/images/icons/included/cancel.png' },
];
---
<div class="included reveal">
  <div class="included__intro">
    <p class="included__headline">Everything Included.</p>
    <p class="included__sub">One simple monthly price.<br />No surprises.</p>
  </div>
  <ul class="included__items" role="list">
    {items.map((item) => (
      <li class="included__item">
        <img src={item.src} alt="" width="80" height="80" loading="lazy" />
        <span>{item.label}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .included {
    display: flex; align-items: stretch;
    margin-top: clamp(2rem, 3vw, 3rem);
    background: var(--white);
    border: 1px solid rgba(8, 43, 89, 0.10);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 2.5vw, 2rem) clamp(0.75rem, 1.5vw, 1.25rem);
  }

  .included__intro {
    flex: 0 0 auto;
    display: flex; flex-direction: column; justify-content: center; gap: 0.75rem;
    padding-inline: clamp(1.25rem, 2vw, 2rem);
  }
  .included__headline {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(1.75rem, 1.4rem + 1.2vw, 2.25rem);
    line-height: 1.1;
    color: var(--navy);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .included__sub {
    font-family: var(--font-serif);
    font-size: var(--text-note);
    line-height: 1.4;
    color: var(--navy);
  }

  .included__items {
    flex: 1 1 0;
    display: flex; align-items: stretch;
    list-style: none; margin: 0; padding: 0;
  }
  .included__item {
    flex: 1 1 0; min-width: 0;
    display: flex; flex-direction: column; align-items: center; gap: 0.75rem;
    padding: 0.25rem 0.65rem;
    border-left: 1px solid rgba(8, 43, 89, 0.18);
    text-align: center;
  }
  .included__item img { width: 80px; height: 80px; object-fit: contain; }
  .included__item span {
    font-family: var(--font-sans); font-weight: 600;
    font-size: var(--text-note); line-height: 1.3;
    color: var(--navy);
  }

  /* Stack: intro on top, items wrap into a grid. */
  @media (max-width: 1280px) {
    .included { flex-direction: column; gap: 1.75rem; text-align: center; }
    .included__intro { align-items: center; }
    .included__items {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem 0;
    }
    .included__item { border-left: 0; }
  }
  @media (max-width: 760px) {
    .included__items { grid-template-columns: repeat(2, 1fr); }
    /* 7 items in 2 columns: center the odd one out. */
    .included__item:last-child { grid-column: 1 / -1; }
  }
</style>
