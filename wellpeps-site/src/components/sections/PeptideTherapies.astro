---
/**
 * Peptide & Wellness Therapies — four-card therapy grid implemented from
 * the approved Claude Design comp ("Peptide Wellness Therapies.dc.html").
 * The comp's "Everything Included." bar renders in the article rail instead
 * (client direction). Rendered inside the article
 * column on Peptide & Wellness Therapies learning-center articles, between
 * the prose and Key Takeaways, so the grid is tuned to a two-up layout at
 * article width rather than the comp's four-up full-bleed.
 */
const IMG = '/images/peptide-therapies';

interface Therapy {
  name: string;
  tagline: string;
  description: string;
  price: number;
  features: [string, string, string];
  photo: string;
  photoAlt: string;
  vial: string;
  vialAlt: string;
  /* Vial overlay geometry from the comp, as % of the photo box. */
  vialPos: string;
  icon: string;
}

const therapies: Therapy[] = [
  {
    name: 'Glutathione',
    tagline: 'Powerful Antioxidant Support',
    description:
      'Supports detoxification, immune health, and protection against oxidative stress.*',
    price: 129,
    features: ['All-Inclusive Pricing', 'Antioxidant Support', 'Cellular Health'],
    photo: `${IMG}/photo-1.png`,
    photoAlt: 'Woman relaxing in warm sunlight',
    vial: `${IMG}/vial-1.png`,
    vialAlt: 'Glutathione vial',
    vialPos: 'left:71.4%;top:65.7%;width:25.4%',
    icon: 'M12 3.5l6.5 2.4v4.8c0 4.2-2.8 7.2-6.5 8.8-3.7-1.6-6.5-4.6-6.5-8.8V5.9L12 3.5zM9.4 12l1.9 1.9 3.3-3.6',
  },
  {
    name: 'Sermorelin',
    tagline: 'Support Healthy Aging & Recovery',
    description:
      'Supports natural growth hormone production to help promote lean muscle, recovery, sleep quality, and healthy aging.*',
    price: 149,
    features: ['All-Inclusive Pricing', 'Recovery Support', 'Healthy Aging'],
    photo: `${IMG}/photo-2.png`,
    photoAlt: 'Man hiking in the mountains',
    vial: `${IMG}/vial-2.png`,
    vialAlt: 'Sermorelin vial',
    vialPos: 'left:65.4%;top:62.8%;width:31.1%',
    icon: 'M7.5 4h9M7.5 20h9M8.5 4.5v2c0 2.6 3.5 3.6 3.5 5.5s-3.5 2.9-3.5 5.5v2M15.5 4.5v2c0 2.6-3.5 3.6-3.5 5.5s3.5 2.9 3.5 5.5v2',
  },
  {
    name: 'MIC + B12',
    tagline: 'Metabolic Support',
    description:
      'Supports healthy metabolism, fat utilization, and natural energy production.*',
    price: 119,
    features: ['All-Inclusive Pricing', 'Metabolism Support', 'Energy Support'],
    photo: `${IMG}/photo-3.png`,
    photoAlt: 'Woman jogging along the coast',
    vial: `${IMG}/vial-3.png`,
    vialAlt: 'B12 MIC vial',
    vialPos: 'left:70%;top:66.5%;width:25.4%',
    icon: 'M12 4.5s5 5.6 5 9.3a5 5 0 11-10 0c0-3.7 5-9.3 5-9.3z',
  },
  {
    name: 'NAD+ Therapy',
    tagline: 'Cellular Energy & Vitality',
    description:
      'Supports healthy cellular energy production, helping promote energy, mental clarity, and healthy aging.*',
    price: 169,
    features: ['All-Inclusive Pricing', 'Cellular Energy', 'Healthy Aging'],
    photo: `${IMG}/photo-4.png`,
    photoAlt: 'Woman stretching in a pool',
    vial: `${IMG}/vial-4.png`,
    vialAlt: 'NAD+ vial',
    vialPos: 'left:71.8%;top:67.4%;width:26.5%',
    icon: 'M13 3.5L6.5 13.5H11L10.5 20.5L17.5 10.5H13L13 3.5z',
  },
];

---

<section class="therapies" aria-labelledby="peptide-therapies-title">
  <h2 class="therapies__title" id="peptide-therapies-title">Peptide &amp; Wellness Therapies</h2>
  <p class="therapies__intro">
    WellPeps offers advanced peptide therapies designed to support your energy,
    recovery, metabolism, and overall wellness. Your provider will recommend the
    therapy that&rsquo;s right for you after reviewing your health history.
  </p>

  <div class="therapies__grid">
    {therapies.map((t) => (
      <article class="tcard">
        <div class="tcard__media">
          <img src={t.photo} alt={t.photoAlt} loading="lazy" decoding="async" />
          <img class="tcard__vial" src={t.vial} alt={t.vialAlt} style={t.vialPos} loading="lazy" decoding="async" />
        </div>
        <div class="tcard__body">
          <div class="tcard__head">
            <span class="tcard__icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={t.icon}></path></svg>
            </span>
            <span class="tcard__name">{t.name}</span>
          </div>
          <p class="tcard__tagline">{t.tagline}</p>
          <p class="tcard__desc">{t.description}</p>
          <div class="tcard__pricing">
            <span class="tcard__price-label">Starting at</span>
            <span class="tcard__price-row">
              <span class="tcard__price">${t.price}</span>
              <span class="tcard__price-unit">/month</span>
            </span>
          </div>
          <ul class="tcard__features">
            {t.features.map((f) => (
              <li>
                <svg width="18" height="18" viewBox="0 0 20 20" aria-hidden="true"><circle cx="10" cy="10" r="9" fill="var(--blue)"></circle><path d="M6 10.3l2.5 2.5 5.5-5.6" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <a href="/peptides" class="tcard__cta">Learn More</a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .therapies {
    margin-top: 2.75rem;
    padding-top: 2.25rem;
    border-top: 1px solid var(--border);
  }
  .therapies__title {
    font-family: var(--font-serif);
    font-size: calc(var(--text-body-size) * 1.55);
    color: var(--navy);
    margin-bottom: 0.85rem;
  }
  .therapies__intro {
    font-size: var(--text-body-size);
    line-height: 1.6;
    margin-bottom: 1.75rem;
  }

  /* ---- Card grid: two-up at article width, one column on small screens ---- */
  .therapies__grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: stretch;
  }
  @media (max-width: 40rem) {
    .therapies__grid { grid-template-columns: minmax(0, 1fr); }
  }

  .tcard {
    display: flex;
    flex-direction: column;
    background: #fcfdff;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .tcard__media { position: relative; }
  .tcard__media > img:first-child { display: block; width: 100%; height: auto; }
  .tcard__vial { position: absolute; height: auto; }

  .tcard__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 0.9rem 1.25rem 1.25rem;
  }
  .tcard__head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 2.75rem;
  }
  .tcard__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: var(--blue);
    background: var(--medallion-bg);
    box-shadow: 0 0 0 1.5px var(--medallion-ring), var(--shadow-sm);
    flex: none;
  }
  .tcard__name {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: var(--text-card-title);
    color: var(--navy);
  }
  .tcard__tagline {
    margin: 0.1rem 0 0.6rem 3.25rem;
    font-weight: 700;
    font-size: var(--text-body-size);
    color: var(--blue);
  }
  .tcard__desc {
    margin: 0;
    font-size: var(--text-body-size);
    line-height: 1.55;
    flex: 1;
    text-wrap: pretty;
  }

  .tcard__pricing {
    border-top: 1px solid var(--border);
    margin-top: 1rem;
    padding-top: 0.85rem;
  }
  .tcard__price-label {
    display: block;
    font-size: var(--price-label);
    color: var(--text-muted);
  }
  .tcard__price-row { display: flex; align-items: baseline; gap: 0.25rem; }
  .tcard__price {
    font-weight: 700;
    font-size: var(--price-amount);
    color: var(--navy);
  }
  .tcard__price-unit { font-size: var(--price-unit); color: var(--text-muted); }

  .tcard__features {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin: 1rem 0 1.25rem;
    padding: 0;
    list-style: none;
  }
  .tcard__features li { display: flex; align-items: center; gap: 0.6rem; }
  .tcard__features svg { flex: none; }
  .tcard__features span {
    font-size: var(--text-body-size);
    font-weight: 500;
    color: var(--navy);
  }

  /* CTA — brand-blue fill on hover with lightened text (client direction). */
  .tcard__cta {
    display: block;
    margin-top: auto;
    text-align: center;
    padding: 0.8rem 0;
    border: 1.5px solid var(--border-strong);
    border-radius: 9px;
    background: #fff;
    font-weight: 700;
    font-size: var(--text-body-size);
    color: var(--blue);
    transition: background var(--dur-fast), border-color var(--dur-fast), color var(--dur-fast);
  }
  .tcard__cta:hover {
    background: var(--blue);
    border-color: var(--blue);
    color: #F2F7FE;
  }

</style>
