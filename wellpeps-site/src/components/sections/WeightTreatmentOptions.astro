---
/**
 * Weight Management Treatment Options — three-plan card grid plus the
 * "Everything Included." bar, implemented from the approved Claude Design
 * comp ("WellPeps Treatment Options.dc.html", option 1a). Rendered inside
 * the article column on Weight Management learning-center articles, between
 * the prose and Key Takeaways.
 *
 * Plan photos reuse the Weight Loss page's product vial shots per the comp's
 * upload note ("Use Correct Pics from Weight Loss Page"), with the same
 * contain-on-white treatment that page uses. Pricing carries the weight
 * page's 52-week "*" footnote, which the comp omits, so the legal treatment
 * matches everywhere the prices appear.
 */
import EverythingIncludedBar from './EverythingIncludedBar.astro';

interface PlanFeature {
  text: string;
  /** First feature per the comp — rendered as a filled blue pill. */
  highlight?: boolean;
}

interface Plan {
  name: string;
  image: string;
  alt: string;
  price: number;
  features: PlanFeature[];
}

const plans: Plan[] = [
  {
    name: 'Semaglutide Injection',
    image: '/images/weight/product-semaglutide.webp',
    alt: 'Compounded semaglutide injection vial',
    price: 179,
    features: [
      { text: 'All-Inclusive Pricing', highlight: true },
      { text: 'Weekly injection' },
      { text: 'Helps regulate appetite' },
    ],
  },
  {
    name: 'Tirzepatide Injection',
    image: '/images/weight/product-tirzepatide.webp',
    alt: 'Compounded tirzepatide injection vial',
    price: 269,
    features: [
      { text: 'All-Inclusive Pricing', highlight: true },
      { text: 'Dual GIP/GLP-1 medication' },
      { text: 'Weekly injection' },
    ],
  },
  {
    name: 'Oral Semaglutide Tablets',
    image: '/images/weight/product-oral.webp',
    alt: 'Oral semaglutide tablets',
    price: 209,
    features: [
      { text: 'All-Inclusive Pricing', highlight: true },
      { text: 'Needle-free option' },
      { text: 'Daily tablet' },
    ],
  },
];
---

<section class="wtopts" aria-labelledby="weight-treatment-options-title">
  <h2 class="wtopts__title" id="weight-treatment-options-title">Weight Management Treatment Options</h2>
  <p class="wtopts__intro">
    If you&rsquo;re exploring GLP-1 medications, WellPeps offers several
    provider-guided treatment options designed around your individual health
    needs and goals.
  </p>
  <p class="wtopts__intro">
    Your provider will recommend the treatment that&rsquo;s right for you
    after reviewing your health history.
  </p>

  <div class="wtopts__grid">
    {plans.map((p) => (
      <article class="wocard">
        <div class="wocard__media">
          <img src={p.image} alt={p.alt} width="1000" height="750" decoding="async" />
        </div>
        <div class="wocard__body">
          <h3 class="wocard__name">{p.name}</h3>
          <div class="wocard__pricing">
            <span class="wocard__price-label">Starting at</span>
            <span class="wocard__price-row">
              <span class="wocard__price">${p.price}</span>
              <span class="wocard__price-unit">/month*</span>
            </span>
          </div>
          <ul class="wocard__features">
            {p.features.map((f) => (
              <li class:list={['wocard__feature', { 'wocard__feature--hi': f.highlight }]}>
                <svg width="18" height="18" viewBox="0 0 20 20" aria-hidden="true"><circle cx="10" cy="10" r="9" fill="var(--blue)"></circle><path d="M6 10.3l2.5 2.5 5.5-5.6" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                <span>{f.text}</span>
              </li>
            ))}
          </ul>
          <a href="/weight-loss" class="wocard__cta">Learn More</a>
        </div>
      </article>
    ))}
  </div>

  <p class="wtopts__pricenote">
    * Starting price reflects a 52-week plan. Actual pricing depends on your
    provider&rsquo;s recommended plan.
  </p>

  <EverythingIncludedBar />
</section>

<style>
  .wtopts {
    margin-top: 2.75rem;
    padding-top: 2.25rem;
    border-top: 1px solid var(--border);
    /* Container so the plan grid tracks the article column, not the viewport —
       the column narrows when the sticky rail sits beside it. */
    container-type: inline-size;
  }
  .wtopts__title {
    font-family: var(--font-serif);
    font-size: calc(var(--text-body-size) * 1.55);
    color: var(--navy);
    margin-bottom: 0.85rem;
  }
  .wtopts__intro {
    font-size: var(--text-body-size);
    line-height: 1.6;
    margin-bottom: 0.85rem;
  }
  .wtopts__intro:last-of-type { margin-bottom: 1.75rem; }

  /* ---- Plan grid: three-up when the column allows, otherwise stacked ---- */
  .wtopts__grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: minmax(0, 1fr);
    align-items: stretch;
  }
  @container (min-width: 42rem) {
    .wtopts__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  .wocard {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  /* Vial shots float on white, matching the Weight Loss page's product grid. */
  .wocard__media {
    display: grid;
    place-items: center;
    background: #fff;
    padding: 1rem 1.25rem 0.75rem;
  }
  .wocard__media img {
    display: block;
    height: clamp(150px, 18cqw, 200px);
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .wocard__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.1rem 1.25rem 1.25rem;
  }
  .wocard__name {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: var(--text-card-title);
    color: var(--navy);
    margin: 0;
    text-wrap: balance;
  }

  .wocard__pricing { margin-top: 0.85rem; }
  .wocard__price-label {
    display: block;
    font-size: var(--price-label);
    color: var(--text-muted);
  }
  .wocard__price-row { display: flex; align-items: baseline; gap: 0.25rem; }
  .wocard__price {
    font-weight: 800;
    font-size: var(--price-amount);
    color: var(--navy);
  }
  .wocard__price-unit { font-size: var(--price-unit); color: var(--text-muted); }

  .wocard__features {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    flex: 1;
  }
  .wocard__feature {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .wocard__feature svg { flex: none; }
  .wocard__feature span { font-size: var(--text-body-size); line-height: 1.35; }
  /* "All-Inclusive Pricing" pill per the comp — filled light-sky row. */
  .wocard__feature--hi {
    background: var(--bg-light-sky);
    border-radius: 8px;
    padding: 0.55rem 0.75rem;
  }
  .wocard__feature--hi span {
    font-weight: 600;
    color: var(--blue);
  }

  /* CTA — outlined per the comp, brand-blue fill on hover (client direction). */
  .wocard__cta {
    display: block;
    margin-top: 1.1rem;
    text-align: center;
    padding: 0.8rem 0;
    border: 1.5px solid var(--blue);
    border-radius: 9px;
    background: #fff;
    font-weight: 600;
    font-size: var(--text-body-size);
    color: var(--blue);
    transition: background var(--dur-fast), color var(--dur-fast);
  }
  .wocard__cta:hover {
    background: var(--blue);
    color: #F2F7FE;
  }

  .wtopts__pricenote {
    margin: 1rem 0 0;
    font-weight: 700;
    color: var(--blue);
    font-size: var(--text-legal);
  }
</style>
