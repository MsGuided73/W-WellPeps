---
import Icon from '../Icon.astro';
import { ONBOARDING_URL } from '../../config';
---
<section class="finalcta">
  <!-- Hero-style treatment: the photo bleeds off the right edge and feathers
       into the light background on its left, so image + copy read as one band
       (no floating card, no boxed image). -->
  <img class="finalcta__img" src="/images/cta-couple.jpg" width="603" height="604"
       alt="A smiling couple enjoying the outdoors at the beach" loading="lazy" />

  <div class="finalcta__wrap">
    <div class="finalcta__copy reveal">
      <h2>Ready to Start Your<br /><span class="accent">Wellness</span> Journey?</h2>
      <hr class="rule rule--left" />
      <a href={ONBOARDING_URL} class="btn btn--primary btn--lg finalcta__btn">Start Your Free Assessment <Icon name="arrow-right" /></a>
      <p class="finalcta__note">It only takes a few minutes.</p>
    </div>
  </div>
</section>

<style>
  .finalcta {
    position: relative;
    overflow: hidden;
    background: var(--bg-soft-ivory);
    display: flex; align-items: center;
    /* Taller band (matches the category-page CTAs) so the square source photo
       needs far less vertical cropping. */
    min-height: clamp(560px, 52vw, 800px);
  }

  /* Bleed to the viewport's right edge; feather into the background on the left. */
  .finalcta__img {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 56vw;
    height: 100%;
    object-fit: cover;
    object-position: center 12%;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.55) 20%, #000 38%);
            mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.55) 20%, #000 38%);
  }

  .finalcta__wrap {
    position: relative; z-index: 2;
    width: 100%; max-width: var(--content-max);
    margin-inline: auto; padding-inline: var(--gutter);
  }
  .finalcta__copy { max-width: clamp(340px, 44vw, 580px); padding-block: clamp(2.5rem, 4vw, 4.25rem); }
  .finalcta__copy h2 { font-size: clamp(2.1rem, 1.3rem + 3vw, 3.6rem); font-weight: 700; letter-spacing: -0.02em; color: var(--navy); line-height: 1.08; }
  .finalcta__btn { margin-top: 1.5rem; align-self: flex-start; }
  .finalcta__note { margin-top: 1rem; color: var(--text-muted); font-size: var(--text-note); }

  @media (max-width: 900px) {
    .finalcta { flex-direction: column; min-height: 0; align-items: stretch; }
    .finalcta__img {
      position: relative; inset: auto; width: 100%; height: clamp(260px, 60vw, 400px);
      object-position: center 30%;
      -webkit-mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
              mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
    }
    .finalcta__copy { max-width: none; padding-block: 2rem 2.75rem; }
  }
</style>
