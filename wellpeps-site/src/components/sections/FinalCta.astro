---
import Icon from '../Icon.astro';
import { ONBOARDING_URL } from '../../config';
---
<section class="finalcta-wrap section">
  <div class="container">
    <div class="finalcta reveal">
      <div class="finalcta__copy">
        <h2>Ready to Start Your<br /><span class="accent">Wellness</span> Journey?</h2>
        <hr class="rule rule--left" />
        <a href={ONBOARDING_URL} class="btn btn--primary btn--lg">Start Your Free Assessment <Icon name="arrow-right" /></a>
        <p class="finalcta__note">It only takes a few minutes.</p>
      </div>
      <div class="finalcta__media">
        <img src="/images/cta-couple.jpg" width="900" height="785"
             alt="A smiling couple enjoying a walk on the beach" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .finalcta-wrap { padding-block: clamp(3rem, 2rem + 3vw, 5rem); }
  .finalcta {
    position: relative; overflow: hidden;
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, #fff 0%, var(--hero-tint) 100%);
    box-shadow: var(--shadow-lg);
    display: grid; grid-template-columns: 1fr 1fr; align-items: stretch;
    min-height: 420px;
  }
  .finalcta__copy { padding: clamp(2.5rem, 4vw, 4.5rem); display: flex; flex-direction: column; justify-content: center; }
  .finalcta__copy h2 { font-size: clamp(2.25rem, 1.4rem + 3vw, 3.6rem); font-weight: 700; letter-spacing: -0.02em; }
  .finalcta__copy .btn { margin-top: 1.5rem; align-self: flex-start; }
  .finalcta__note { margin-top: 1rem; color: var(--text-muted); font-size: var(--text-note); }
  .finalcta__media { position: relative; }
  .finalcta__media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }

  @media (max-width: 800px) {
    .finalcta { grid-template-columns: 1fr; }
    .finalcta__media { min-height: 280px; order: -1; }
    .finalcta__media img { position: relative; }
  }
</style>
