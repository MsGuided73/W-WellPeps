---
import Icon from '../../Icon.astro';
import { sexFaqs } from '../../../data/sexual';
---
<section class="section section--ivory" id="faq">
  <div class="container">
    <div class="section-head reveal">
      <h2>Common Questions</h2>
      <p>Discreet answers to the questions patients ask most about sexual wellness treatment.</p>
    </div>

    <div class="sxfaq__grid reveal">
      {sexFaqs.map((f, i) => (
        <div class="sxfaq__item" data-faq>
          <button aria-expanded="false" aria-controls={`sxfaq-${i}`}>
            <span>{f.q}</span>
            <span class="sxfaq__icon"><Icon name="chevron-down" /></span>
          </button>
          <div class="sxfaq__panel" id={`sxfaq-${i}`}><p>{f.a}</p></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sxfaq__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; max-width: 1080px; margin: clamp(2.5rem, 4vw, 3.5rem) auto 0; }
  .sxfaq__item { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden; align-self: start; transition: box-shadow var(--dur) var(--ease); }
  .sxfaq__item:hover { box-shadow: var(--shadow); }
  .sxfaq__item button {
    width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    background: none; border: 0; cursor: pointer; text-align: left; padding: 1.35rem 1.5rem;
    font-family: var(--font-sans); font-weight: 700; font-size: var(--text-faq-q); color: var(--navy); line-height: 1.35;
  }
  .sxfaq__icon { display: grid; place-items: center; width: 28px; height: 28px; flex: none; color: var(--blue); transition: transform var(--dur) var(--ease); }
  .sxfaq__icon :global(svg) { width: 22px; height: 22px; }
  .sxfaq__item button[aria-expanded='true'] .sxfaq__icon { transform: rotate(180deg); }
  .sxfaq__panel { display: grid; grid-template-rows: 0fr; transition: grid-template-rows var(--dur) var(--ease); }
  .sxfaq__panel > p { overflow: hidden; color: var(--text-body); padding: 0 1.5rem; font-size: var(--text-faq-a); line-height: 1.65; }
  .sxfaq__item button[aria-expanded='true'] + .sxfaq__panel { grid-template-rows: 1fr; }
  .sxfaq__item button[aria-expanded='true'] + .sxfaq__panel > p { padding-bottom: 1.4rem; }

  @media (max-width: 760px) { .sxfaq__grid { grid-template-columns: 1fr; } }
</style>
