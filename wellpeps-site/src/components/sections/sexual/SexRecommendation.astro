---
import Icon from '../../Icon.astro';
import { ONBOARDING_URL } from '../../../config';
import { sexRecommendation } from '../../../data/sexual';

// Break the heading after "Figure" so it reads on two lines on desktop
// ("You Don't Have to Figure" / "It Out Alone."). The <br> is hidden on
// mobile (see styles) so the text wraps naturally on small screens.
const [titleHead, titleTail] = sexRecommendation.title.split(/(?<=Figure)\s+/);
---
<section class="section section--pale-blue sxrec-wrap">
  <!-- Copy left, photo right (per the approved 7-10 notes). -->
  <div class="container sxrec__inner">
    <div class="sxrec reveal">
      <h2>{titleHead}{titleTail && (<Fragment><br class="sxrec__brk" />{' '}{titleTail}</Fragment>)}</h2>
      <hr class="rule rule--left" />
      <p>{sexRecommendation.body}</p>
      <a href={ONBOARDING_URL} class="btn btn--primary btn--lg">Start Your Free Personalized Assessment <Icon name="arrow-right" /></a>
    </div>
    <div class="sxrec__media reveal">
      <img src={sexRecommendation.image} alt={sexRecommendation.alt} width="820" height="620" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .sxrec-wrap { padding-block: clamp(2.5rem, 4vw, 4rem); }
  .sxrec__inner { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(2rem, 4vw, 4rem); align-items: center; }
  .sxrec { display: flex; flex-direction: column; align-items: flex-start; text-align: left; }
  .sxrec h2 { font-size: var(--text-section-title); font-weight: 700; line-height: 1.1; }
  .sxrec .rule { margin-block: 1.1rem 0; }
  .sxrec p { margin-top: 1rem; max-width: 46ch; color: var(--text-body); font-size: var(--text-lead); line-height: 1.6; }
  .sxrec .btn { margin-top: 1.75rem; }

  .sxrec__media { border-radius: var(--radius-lg); overflow: hidden; }
  /* The supplied photo faces left; flip it so she looks toward the copy. */
  .sxrec__media img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4 / 3; transform: scaleX(-1); }

  @media (max-width: 900px) {
    .sxrec__inner { grid-template-columns: 1fr; }
    .sxrec__media { order: -1; }
    /* Drop the forced break so the heading wraps naturally on mobile. */
    .sxrec__brk { display: none; }
  }
</style>
