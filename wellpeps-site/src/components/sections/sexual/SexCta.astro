---
import Icon from '../../Icon.astro';
import { ONBOARDING_URL } from '../../../config';
import { sexCta } from '../../../data/sexual';
---
<section class="sxcta">
  <img class="sxcta__img" src={sexCta.image} width="1500" height="1000" alt={sexCta.alt} loading="lazy" />
  <div class="sxcta__wrap">
    <div class="sxcta__copy reveal">
      <h2>{sexCta.title}<br /><span class="accent">{sexCta.titleAccent}</span></h2>
      <hr class="rule rule--left" />
      <p class="sxcta__lead">{sexCta.lead}</p>
      <a href={ONBOARDING_URL} class="btn btn--primary btn--lg btn--cta sxcta__btn">Start Your Free Assessment <Icon name="arrow-right" /></a>
      <p class="sxcta__note">{sexCta.note}</p>
    </div>
  </div>
</section>

<style>
  .sxcta { position: relative; overflow: hidden; background: var(--bg-warm-cream); display: flex; align-items: center; min-height: clamp(560px, 52vw, 800px); }
  .sxcta__img {
    position: absolute; top: 0; left: 0; bottom: 0; width: 56vw; height: 100%;
    object-fit: cover; object-position: 45% 18%;
    -webkit-mask-image: linear-gradient(to right, #000 46%, rgba(0,0,0,0.4) 74%, transparent 96%);
            mask-image: linear-gradient(to right, #000 46%, rgba(0,0,0,0.4) 74%, transparent 96%);
  }
  .sxcta__wrap { position: relative; z-index: 2; width: 100%; max-width: var(--content-max); margin-inline: auto; padding-inline: var(--gutter); }
  .sxcta__copy { max-width: clamp(340px, 42vw, 560px); margin-left: auto; padding-block: clamp(2.5rem, 4vw, 4.25rem); }
  .sxcta__copy h2 { font-size: clamp(2rem, 1.3rem + 2.6vw, 3.4rem); font-weight: 700; letter-spacing: -0.02em; color: var(--navy); line-height: 1.08; }
  .sxcta__copy .rule { margin-block: 1.25rem; }
  .sxcta__lead { color: var(--text-body); font-size: var(--text-lead); max-width: 40ch; }
  .sxcta__btn { margin-top: 1.75rem; align-self: flex-start; }
  .sxcta__note { margin-top: 1rem; color: var(--navy); font-weight: 700; font-size: var(--text-note); }

  @media (max-width: 900px) {
    .sxcta { flex-direction: column; min-height: 0; align-items: stretch; }
    .sxcta__img {
      position: relative; inset: auto; width: 100%; height: clamp(260px, 60vw, 400px); object-position: center 30%;
      -webkit-mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
              mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
    }
    .sxcta__copy { max-width: none; margin-left: 0; padding-block: 2rem 2.75rem; }
  }
</style>
