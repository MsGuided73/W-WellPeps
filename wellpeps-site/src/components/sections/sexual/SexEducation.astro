---
import { sexEducation, sexWorks } from '../../../data/sexual';
---
<section class="section section--pale-blue" id="how-it-works">
  <div class="container">
    <!-- Photo left, copy right (per the approved 7-10 notes). -->
    <div class="sxedu__top reveal">
      <div class="sxedu__media">
        <img src={sexEducation.image} alt={sexEducation.alt} width="820" height="560" loading="lazy" />
      </div>
      <div class="sxedu__intro">
        <h2>{sexEducation.title}</h2>
        <hr class="rule rule--left" />
        {sexEducation.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <div class="sxedu__works reveal">
      <div class="sxedu__grid">
        {sexWorks.map((s, i) => (
          <article class="card sxedu__step">
            <span class="sxedu__num">{i + 1}</span>
            <h4>{s.title}</h4>
            <p>{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Photo left / copy right band. */
  .sxedu__top { display: grid; grid-template-columns: 1fr 1.1fr; gap: clamp(2rem, 4vw, 4rem); align-items: center; }
  .sxedu__media { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
  .sxedu__media img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 3 / 2; }

  .sxedu__intro h2 { font-size: var(--text-section-title); font-weight: 700; line-height: 1.08; }
  .sxedu__intro .rule { margin-block: 1.1rem 1.4rem; }
  .sxedu__intro p { color: var(--text-body); font-size: var(--text-card-body); line-height: 1.65; }
  .sxedu__intro p + p { margin-top: 1rem; }

  .sxedu__works { margin-top: clamp(2.5rem, 4vw, 3.5rem); }

  .sxedu__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem; text-align: left; }
  .sxedu__step { position: relative; padding: 2.25rem 1.75rem 2rem; overflow: hidden; }
  .sxedu__step:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .sxedu__num { position: absolute; top: 1rem; right: 1.25rem; font-family: var(--font-serif); font-weight: 700; font-size: 2.6rem; color: var(--border-strong); line-height: 1; }
  .sxedu__step h4 { font-family: var(--font-serif); font-weight: 600; font-size: var(--text-card-title); color: var(--navy); line-height: 1.2; }
  .sxedu__step p { margin-top: 0.8rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.6; }

  @media (max-width: 900px) {
    .sxedu__top { grid-template-columns: 1fr; }
    .sxedu__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
  }
</style>
