---
import StandardProductCard from '../../StandardProductCard.astro';
import EverythingIncludedStrip from '../../EverythingIncludedStrip.astro';
import { sexProducts, sexProductsIntro } from '../../../data/sexual';
---
<!-- White background: the pale-blue education section sits directly above, and
     the client flagged two consecutive blue-tinted bands. -->
<section class="section" id="sex-products">
  <div class="container">
    <div class="sxprod__head reveal">
      <h2>{sexProductsIntro.title}</h2>
      <p class="sxprod__lead">{sexProductsIntro.lead}</p>
    </div>

    <div class="sxprod__grid reveal">
      {sexProducts.map((product) => (
        <StandardProductCard
          cover
          image={product.image}
          alt={product.alt}
          name={product.name}
          productName={product.subtitle}
          description={product.description}
          form={product.methodOfUse}
          features={product.features}
          price={product.price}
          priceUnit={product.priceUnit}
          href={product.href}
        />
      ))}
    </div>

    <p class="sxprod__foot reveal">{sexProductsIntro.footnote}</p>

    <EverythingIncludedStrip />
  </div>
</section>

<style>
  .sxprod__head { text-align: center; max-width: 860px; margin-inline: auto; }
  .sxprod__head h2 { font-size: var(--text-section-title); font-weight: 700; }
  .sxprod__lead { margin-top: 1rem; font-size: var(--text-lead); color: var(--text-body); }
  .sxprod__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: clamp(2.5rem, 4vw, 3.5rem); }
  .sxprod__foot { text-align: center; margin-top: 2rem; color: var(--blue); font-weight: 700; font-size: var(--text-note); }

  @media (max-width: 1200px) { .sxprod__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .sxprod__grid { grid-template-columns: 1fr; max-width: 420px; margin-inline: auto; } }
</style>
