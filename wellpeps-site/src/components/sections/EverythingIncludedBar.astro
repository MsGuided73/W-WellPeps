---
/**
 * "Everything Included." bar — shield lead plus the seven all-inclusive items,
 * from the approved Claude Design comps ("Everything Included Bar.dc.html").
 * Shared by the learning-center treatment inserts (PeptideTherapies,
 * SexualTreatmentOptions) so the bar stays identical wherever it appears.
 */
const included = [
  { label: 'Prescription\nMedication', icon: 'M9 8.5V6h5.5v2.5M9.5 12h4.5M7.5 8.5h8.5v9.5a1.5 1.5 0 01-1.5 1.5h-5.5a1.5 1.5 0 01-1.5-1.5z M15 17l1.2 1.2 1.9-2' },
  { label: 'Licensed\nProvider\nEvaluation', icon: 'M12 10.7a3.2 3.2 0 100-6.4 3.2 3.2 0 000 6.4zM5.5 20.5c.8-4 3.4-6 6.5-6s5.7 2 6.5 6M10.8 14.8L12 17.2l1.2-2.4M12 17.2v3' },
  { label: 'Ongoing\nSupport', icon: 'M12 15.5s-4.6-2.9-4.6-6a2.6 2.6 0 014.6-1.7A2.6 2.6 0 0116.6 9.5c0 3.1-4.6 6-4.6 6zM6 19.5c1.8 1.2 4 1.2 6 0 2 1.2 4.2 1.2 6 0' },
  { label: 'Standard\nShipping', icon: 'M3 8.5h10.5v8H3zM13.5 10h3.6l2.9 3v3h-2M9.3 17.5h5.1M7.5 19.3a1.8 1.8 0 100-3.6 1.8 1.8 0 000 3.6zM16.2 19.3a1.8 1.8 0 100-3.6 1.8 1.8 0 000 3.6z' },
  { label: 'No\nMembership\nFees', icon: 'M12 20.2a8.2 8.2 0 100-16.4 8.2 8.2 0 000 16.4zM6.2 6.2l11.6 11.6' },
  { label: 'No\nHidden\nFees', icon: 'M12.8 3.8H19a1.2 1.2 0 011.2 1.2v6.2L11 20.4l-7.4-7.4 9.2-9.2zM8.6 13.2l1.9 1.9 3.4-3.6M17.5 7.7a1.2 1.2 0 11-2.4 0 1.2 1.2 0 012.4 0z' },
  { label: 'Cancel\nAnytime*', icon: 'M3.5 7.3a1.8 1.8 0 011.8-1.8h13.4a1.8 1.8 0 011.8 1.8v9.4a1.8 1.8 0 01-1.8 1.8H5.3a1.8 1.8 0 01-1.8-1.8zM7.5 3.5v4M13.5 3.5v4M3.5 10.5h10M17.2 14.4v1.9l1.3 1M17.2 20a3.8 3.8 0 100-7.6 3.8 3.8 0 000 7.6z' },
];
---

<div class="included">
  <div class="included__lead">
    <svg width="54" height="54" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2.8l7.2 2.7v5.3c0 4.7-3.1 8-7.2 9.9-4.1-1.9-7.2-5.2-7.2-9.9V5.5L12 2.8z"></path></svg>
    <div>
      <p class="included__headline">Everything Included.</p>
      <p class="included__subhead">One simple monthly price.<br />No surprises.</p>
    </div>
  </div>
  <ul class="included__items">
    {included.map((item) => (
      <li class="included__item">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={item.icon}></path></svg>
        <span>{item.label.split('\n').map((line, i) => (
          <>{i > 0 && <br />}{line}</>
        ))}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .included {
    margin-top: 1.5rem;
    background: var(--bg-pale-blue);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.4rem 1.6rem;
  }
  .included__lead {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    color: var(--navy);
    margin-bottom: 1.1rem;
  }
  .included__headline {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: calc(var(--text-body-size) * 1.3);
    color: var(--navy);
    line-height: 1.2;
    margin: 0;
  }
  .included__subhead {
    font-size: var(--text-body-size);
    line-height: 1.45;
    margin: 0.25rem 0 0;
  }
  .included__items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(7.5rem, 1fr));
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .included__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0.55rem;
    text-align: center;
    border-left: 1px solid var(--bg-blue-gray);
    padding: 0.25rem 0.5rem;
    color: var(--navy);
  }
  .included__item span {
    font-size: var(--text-legal);
    line-height: 1.35;
    color: var(--navy);
  }
  @media (max-width: 40rem) {
    .included__item { border-left: 0; }
  }
</style>
