---
import { ONBOARDING_URL } from '../../config';
---
<section class="hero">
  <!-- Image is a direct child of the full-width section so it can bleed to the
       right edge of the viewport (not clipped by the centered text wrapper). -->
  <img class="hero__img" src="/images/hero-couple.jpg" width="1500" height="1000"
       alt="A couple walking together on a coastal trail at sunrise"
       fetchpriority="high" />

  <div class="hero__wrap">
    <div class="hero__copy reveal">
      <h1>Personalized<br />Wellness.<br /><span class="accent">Simplified.</span></h1>
      <hr class="rule rule--left" />
      <p class="hero__lead">Personalized treatment plans, licensed healthcare providers, and ongoing support—all from the comfort of home.</p>
      <div class="hero__actions">
        <a href={ONBOARDING_URL} class="btn btn--primary btn--lg">Start Your Free Assessment</a>
        <a href="/#programs" class="btn btn--secondary btn--lg">Explore Our Programs</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: #fff;
    min-height: clamp(520px, 58vw, 800px);
    display: flex;
    align-items: center;
  }

  /* Full-bleed to the viewport's right edge, square corners, feathers into white */
  .hero__img {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 60vw;
    height: 100%;
    object-fit: cover;
    object-position: 60% center;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.2) 20%, #000 46%);
            mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.2) 20%, #000 46%);
  }

  .hero__wrap {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1760px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 3vw, 3rem);
  }
  .hero__copy {
    max-width: clamp(360px, 44vw, 640px);
    padding-block: clamp(2rem, 4vw, 4rem);
  }
  .hero__copy h1 {
    font-size: clamp(3.25rem, 1.8rem + 6.4vw, 6.5rem);
    line-height: 1.02;
    font-weight: 700; letter-spacing: -0.025em; color: var(--navy);
  }
  .hero__lead {
    font-size: clamp(1.15rem, 1rem + 0.55vw, 1.5rem); color: var(--text-body);
    max-width: 34ch; margin-top: 1.75rem;
  }
  .hero__actions { display: flex; flex-direction: column; gap: 1rem; margin-top: 2.25rem; max-width: 400px; }

  @media (max-width: 860px) {
    .hero { flex-direction: column; min-height: 0; align-items: stretch; }
    .hero__img {
      position: relative; inset: auto; width: 100%; height: clamp(240px, 60vw, 380px);
      object-position: center;
      -webkit-mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
              mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
    }
    .hero__copy { max-width: none; }
    .hero__actions { max-width: none; }
  }
</style>
