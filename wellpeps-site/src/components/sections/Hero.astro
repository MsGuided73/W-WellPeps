---
import Icon from '../Icon.astro';
import { ONBOARDING_URL } from '../../config';
---
<section class="hero">
  <!-- Image is a direct child of the full-width section so it can bleed to the
       right edge of the viewport (not clipped by the centered text wrapper). -->
  <img class="hero__img" src="/images/hero-couple-coast.webp" width="1666" height="944"
       alt="A smiling couple walking arm in arm along a coastal trail at sunset"
       fetchpriority="high" />

  <div class="hero__wrap">
    <div class="hero__copy reveal">
      <h1><span class="hero__line">Personalized</span><span class="hero__rotator" data-rotator><span class="hero__rotate-word">Wellness.</span></span><span class="hero__line">Simplified.</span></h1>
      <hr class="rule rule--left" />
      <p class="hero__lead">Personalized treatment plans, licensed healthcare providers, and ongoing support—all from the comfort of home.</p>
      <div class="hero__actions">
        <a href={ONBOARDING_URL} class="btn btn--primary btn--lg">Start Free Online Assessment</a>
        <a href="/#programs" class="btn btn--secondary btn--lg">Explore Treatment Options <Icon name="arrow-right" /></a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: #fff;
    min-height: clamp(520px, 58vw, 800px);
    display: flex;
    align-items: center;
  }

  /* Full-bleed to the viewport's right edge, square corners, feathers into white */
  .hero__img {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 60vw;
    height: 100%;
    object-fit: cover;
    /* Source is 16:9 — wider than this frame, so `cover` crops left/right and
       never the heads. The couple sits in the right third of the photo; hold
       the crop window right so they stay put and the ocean fills the feather. */
    object-position: 85% center;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.2) 20%, #000 46%);
            mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.2) 20%, #000 46%);
  }

  .hero__wrap {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1760px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 3vw, 3rem);
  }
  .hero__copy {
    max-width: clamp(360px, 44vw, 640px);
    padding-block: clamp(2rem, 4vw, 4rem);
  }
  .hero__copy h1 {
    font-size: clamp(3.25rem, 1.8rem + 6.4vw, 6.5rem);
    line-height: 1.02;
    font-weight: 700; letter-spacing: -0.025em; color: var(--navy);
  }
  /* Rotating headline word — its own line so width changes never shift
     "Simplified." below it. Left-aligned, so words grow rightward. */
  /* Each headline line is a block so they stack cleanly at exactly 3 lines
     (no <br>). The rotator's width = the copy column, and its word never
     wraps — JS (fitWord) scales it to fit one line. */
  .hero__line { display: block; }
  .hero__rotator { display: block; }
  .hero__rotate-word {
    /* The rotating word is the hero's accent — it tracks the brand action blue
       from the token, never a hard-coded copy of it. */
    color: var(--blue);
    display: inline-block;
    white-space: nowrap;
    transform-origin: left center;
    transition: opacity 380ms var(--ease), transform 380ms var(--ease);
  }
  .hero__rotate-word.is-out { opacity: 0; transform: translateY(0.18em); }
  @media (prefers-reduced-motion: reduce) {
    .hero__rotate-word { transition: none; }
    .hero__rotate-word.is-out { transform: none; }
  }

  .hero__lead {
    font-size: clamp(1.1875rem, 1.1rem + 0.55vw, 1.5rem); color: var(--text-body);
    max-width: 34ch; margin-top: 1.75rem;
  }
  .hero__actions { display: flex; flex-direction: column; gap: 1rem; margin-top: 2.25rem; max-width: 400px; }

  @media (max-width: 860px) {
    .hero { flex-direction: column; min-height: 0; align-items: stretch; }
    .hero__img {
      position: relative; inset: auto; width: 100%; height: clamp(240px, 60vw, 380px);
      /* Full-width band is wider than 16:9, so the crop is vertical here —
         bias up to keep the couple's faces off the bottom edge. */
      object-position: center 30%;
      -webkit-mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
              mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
    }
    .hero__copy { max-width: none; }
    .hero__actions { max-width: none; }
  }
</style>

<script>
  // Rotating hero word — swaps text every 3s with a fade/slide. Colour is NOT
  // set here: .hero__rotate-word carries var(--blue) so the word always tracks
  // the brand action blue rather than a copy of it.
  const ROTATE_WORDS = [
    'Wellness.', 'Weight Loss.', 'Hair Growth.', 'Sexual Wellness.',
    'Healthy Aging.', 'Energy & Vitality.', 'Recovery.',
  ];
  const INTERVAL_MS = 3000;

  const rotator = document.querySelector('[data-rotator]');
  const word = rotator?.querySelector('.hero__rotate-word');
  if (word) {
    // Keep the phrase on one line (3-line headline). Let it grow past the
    // text column into the faint left edge of the hero photo, and only shrink
    // if it would reach the image's subject zone (~52vw). On the stacked
    // mobile layout (<=860px) there's no side image, so fit to the column.
    const SAFE_RIGHT_VW = 0.52;
    const fitWord = () => {
      word.style.fontSize = '';                       // reset to inherited (fluid) size
      const stacked = window.innerWidth <= 860;
      const left = rotator.getBoundingClientRect().left;
      const avail = stacked
        ? rotator.clientWidth
        : Math.max(rotator.clientWidth, window.innerWidth * SAFE_RIGHT_VW - left);
      const natural = word.getBoundingClientRect().width;
      if (avail > 0 && natural > avail) {
        const base = parseFloat(getComputedStyle(word).fontSize);
        word.style.fontSize = (base * (avail / natural) * 0.99) + 'px';
      }
    };

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const OUT_MS = reduce ? 0 : 380; // must match the CSS transition duration
    let i = 0;

    fitWord(); // fit the initial word
    window.addEventListener('resize', fitWord);

    setInterval(() => {
      word.classList.add('is-out');
      setTimeout(() => {
        i = (i + 1) % ROTATE_WORDS.length;
        word.textContent = ROTATE_WORDS[i];

        fitWord();                    // scale while invisible, then fade in
        word.classList.remove('is-out');
      }, OUT_MS);
    }, INTERVAL_MS);
  }
</script>
