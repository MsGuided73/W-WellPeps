---
import { ONBOARDING_URL } from '../../../config';
import { hairCta } from '../../../data/hair';
---
<section class="hcta">
  <!-- One continuous cream background: the photo bleeds off the right edge and
       feathers into the cream on its left, so image + copy read as a single
       band (no floating card, no boxed image). -->
  <img class="hcta__img" src={hairCta.image} width="1500" height="1000" alt={hairCta.alt} loading="lazy" />

  <div class="hcta__wrap">
    <div class="hcta__copy reveal">
      <h2>{hairCta.title}</h2>
      <p class="hcta__lead">{hairCta.lead}</p>
      <a href={ONBOARDING_URL} class="btn btn--primary btn--lg hcta__btn">Start Your Free Assessment</a>
      <p class="hcta__note">{hairCta.note}</p>
    </div>
  </div>
</section>

<style>
  .hcta {
    position: relative;
    overflow: hidden;
    background: var(--bg-warm-cream);
    display: flex; align-items: center;
    min-height: clamp(480px, 50vw, 700px);
  }

  /* Same treatment as the hero (bleed right, feather left) — just a slightly
     smaller scale, and feathering into cream instead of white. */
  .hcta__img {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 56vw;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    -webkit-mask-image: linear-gradient(to right, transparent 4%, rgba(0,0,0,0.4) 26%, #000 54%);
            mask-image: linear-gradient(to right, transparent 4%, rgba(0,0,0,0.4) 26%, #000 54%);
  }

  .hcta__wrap {
    position: relative; z-index: 2;
    width: 100%; max-width: var(--content-max);
    margin-inline: auto; padding-inline: var(--gutter);
  }
  .hcta__copy { max-width: clamp(340px, 42vw, 560px); padding-block: clamp(2.5rem, 4vw, 4.25rem); }
  .hcta__copy h2 { font-size: clamp(1.9rem, 1.2rem + 2.3vw, 3rem); font-weight: 700; letter-spacing: -0.02em; color: var(--navy); line-height: 1.1; }
  .hcta__lead { margin-top: 1.1rem; color: var(--text-body); font-size: var(--text-lead); max-width: 30ch; }
  .hcta__btn { margin-top: 1.75rem; align-self: flex-start; }
  .hcta__note { margin-top: 1rem; color: var(--navy); font-weight: 700; font-size: var(--text-note); }

  @media (max-width: 900px) {
    .hcta { flex-direction: column; min-height: 0; align-items: stretch; }
    .hcta__img {
      position: relative; inset: auto; width: 100%; height: clamp(260px, 60vw, 400px);
      object-position: center 22%;
      -webkit-mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
              mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
    }
    .hcta__copy { max-width: none; padding-block: 2rem 2.75rem; }
  }
</style>
