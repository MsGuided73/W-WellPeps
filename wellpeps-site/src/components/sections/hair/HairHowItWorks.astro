---
import { hairWorks } from '../../../data/hair';
---
<section class="section section--pale-blue" id="how-it-works">
  <div class="container">
    <div class="section-head reveal">
      <h2>How Hair Restoration Treatments Work</h2>
    </div>

    <div class="hworks__grid reveal">
      {hairWorks.map((step) => (
        <article class="card hworks__card">
          <div class="hworks__media"><img src={step.image} alt={step.alt} width="760" height="520" loading="lazy" /></div>
          <div class="hworks__body">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .hworks__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem;
    margin-top: clamp(2rem, 3vw, 3rem);
  }
  .hworks__card { overflow: hidden; display: flex; flex-direction: column; text-align: center; }
  .hworks__card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .hworks__media { aspect-ratio: 16 / 10; overflow: hidden; }
  .hworks__media img { width: 100%; height: 100%; object-fit: cover; }
  .hworks__body { padding: 1.75rem 1.6rem 2rem; display: flex; flex-direction: column; align-items: center; flex: 1; }
  .hworks__body h3 { font-size: var(--text-card-title); font-weight: 600; line-height: 1.2; }
  .hworks__body p { margin-top: 0.9rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.6; }

  @media (max-width: 900px) {
    .hworks__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
  }
</style>
