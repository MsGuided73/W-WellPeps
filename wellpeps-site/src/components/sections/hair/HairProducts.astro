---
import Icon from '../../Icon.astro';
import ProductCard from '../../ProductCard.astro';
import { hairProducts, hairProductsIntro } from '../../../data/hair';
import { ONBOARDING_URL } from '../../../config';
---
<section class="section section--gray" id="hair-products">
  <div class="container">
    <div class="hprod__head reveal">
      <h2>{hairProductsIntro.title}</h2>
      <p class="hprod__intro">{hairProductsIntro.intro}</p>
    </div>

    <div class="hprod__grid reveal">
      {hairProducts.map((product) => <ProductCard product={product} />)}
    </div>

    <div class="hprod__band reveal">
      <div class="hprod__band-copy">
        <span class="hprod__band-icon"><Icon name="user" /></span>
        <div>
          <p class="hprod__band-title">Personalized Programs</p>
          <p class="hprod__band-text">Your treatment plan is customized based on your hair loss pattern, goals, medical history, and provider evaluation.</p>
        </div>
      </div>
      <a href={ONBOARDING_URL} class="btn btn--primary hprod__band-cta">Find Your Program <Icon name="arrow-right" /></a>
    </div>

    <p class="hprod__foot reveal"><Icon name="shield" /> {hairProductsIntro.footnote}</p>
  </div>
</section>

<style>
  /* Full width so the title fits on one line at desktop sizes. */
  .hprod__head { text-align: center; margin-inline: auto; }
  .hprod__head h2 { font-size: var(--text-section-title); font-weight: 700; }
  .hprod__intro { margin-top: 1rem; font-size: var(--text-lead); color: var(--text-body); max-width: 66ch; margin-inline: auto; }

  .hprod__grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }

  .hprod__band {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1.5rem;
    margin-top: 2rem; padding: 1.75rem 2rem;
    background: var(--bg-wellness); border-radius: var(--radius-lg);
  }
  .hprod__band-copy { display: flex; align-items: center; gap: 1.1rem; max-width: 760px; }
  .hprod__band-icon {
    display: inline-grid; place-items: center; flex: none;
    width: 54px; height: 54px; border-radius: 50%;
    background: var(--medallion-bg); border: 1px solid var(--medallion-ring);
    box-shadow: var(--medallion-shadow); color: var(--blue);
  }
  .hprod__band-icon :global(svg) { width: 26px; height: 26px; filter: var(--icon-shadow); }
  .hprod__band-title { font-family: var(--font-serif); font-weight: 700; font-size: 1.4rem; color: var(--navy); }
  .hprod__band-text { margin-top: 0.25rem; color: var(--text-body); font-size: 1rem; line-height: 1.5; }
  .hprod__band-cta { flex: none; }

  .hprod__foot {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    margin-top: 1.75rem; color: var(--text-muted); font-size: var(--text-note);
  }
  .hprod__foot :global(svg) { width: 18px; height: 18px; color: var(--blue-soft); }

  @media (max-width: 1200px) { .hprod__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) {
    .hprod__grid { grid-template-columns: 1fr; max-width: 420px; margin-inline: auto; }
    .hprod__band { flex-direction: column; align-items: flex-start; }
    .hprod__band-cta { width: 100%; }
  }
</style>
