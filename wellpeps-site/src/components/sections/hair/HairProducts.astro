---
import ProductCard from '../../ProductCard.astro';
import { hairProducts, hairProductsIntro } from '../../../data/hair';
---
<section class="section section--gray" id="hair-products">
  <div class="container">
    <div class="hprod__head reveal">
      <h2>{hairProductsIntro.title}</h2>
      <p class="hprod__intro">{hairProductsIntro.intro}</p>
    </div>

    <div class="hprod__grid reveal">
      {hairProducts.map((product) => <ProductCard product={product} />)}
    </div>

    <p class="hprod__foot reveal">{hairProductsIntro.footnote}</p>
  </div>
</section>

<style>
  /* Full width so the title fits on one line at desktop sizes. */
  .hprod__head { text-align: center; margin-inline: auto; }
  .hprod__head h2 { font-size: var(--text-section-title); font-weight: 700; }
  .hprod__intro { margin-top: 1rem; font-size: var(--text-lead); color: var(--text-body); max-width: 66ch; margin-inline: auto; }

  .hprod__grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }

  .hprod__foot {
    text-align: center; margin-top: 2.5rem;
    color: var(--blue); font-weight: 700; font-size: var(--text-note);
  }

  @media (max-width: 1200px) { .hprod__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) {
    .hprod__grid { grid-template-columns: 1fr; max-width: 420px; margin-inline: auto; }
  }
</style>
