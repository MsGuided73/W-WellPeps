---
import Icon from '../../Icon.astro';
import { weightWorks, weightWorksIntro, weightWorksNotes } from '../../../data/weight';
---
<section class="section section--ivory" id="how-it-works">
  <div class="container">
    <div class="section-head reveal">
      <h2>{weightWorksIntro.title}</h2>
      <p>{weightWorksIntro.lead}</p>
    </div>

    <div class="wworks__grid reveal">
      {weightWorks.map((step) => (
        <article class="wworks__step">
          <h3>{step.title}</h3>
          <hr class="rule" />
          <p>{step.body}</p>
        </article>
      ))}
    </div>

    <div class="wworks__notes reveal">
      {weightWorksNotes.map((n) => (
        <div class="wworks__note">
          <span class="wworks__note-badge"><Icon name={n.icon} /></span>
          <div class="wworks__note-copy">
            <strong>{n.lead}</strong>
            <p>{n.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Widen the standard section header so the title fits on one line at
     desktop sizes. The lead is widened past the shared 760px measure so the
     141-character sentence lands on two lines instead of three. */
  .section-head { max-width: none; }
  .section-head p { max-width: 920px; margin-inline: auto; }

  /* Three steps, held to a centered measure so they don't stretch thin
     across the full container width. Shares the 76rem cap with the trust bar
     below so the two blocks stay edge-aligned — keep them in sync. */
  .wworks__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem;
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
    max-width: 76rem; margin-inline: auto;
  }
  .wworks__step { text-align: center; display: flex; flex-direction: column; align-items: center; }
  .wworks__step h3 { font-size: var(--text-card-title); font-weight: 600; line-height: 1.2; }
  .wworks__step .rule { margin-top: 0.9rem; }
  .wworks__step p { margin-top: 0.9rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.55; }

  /* Trust bar: icon medallion + stacked lead/body, so each half reads as a
     deliberate pair instead of a run-on sentence. Held to the same centered
     measure as the step grid above it. */
  /* Uneven columns: the left note is ~34 characters longer than the right, so
     an even split leaves it running four lines while the right runs two.
     Weighting it 1.2/1 lands both on two lines. */
  .wworks__notes {
    display: grid; grid-template-columns: 1.2fr 1fr; gap: 2.5rem;
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
    max-width: 76rem; margin-inline: auto;
    background: #fff; border: 1px solid var(--border); border-radius: var(--radius);
    padding: 2rem 2.5rem; box-shadow: var(--shadow-sm);
  }
  .wworks__note { display: flex; align-items: flex-start; gap: 1.1rem; text-align: left; }
  .wworks__note + .wworks__note { border-left: 1px solid var(--border); padding-left: 2.5rem; }
  .wworks__note-badge {
    flex: none; display: grid; place-items: center;
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--bg-wellness); color: var(--blue);
  }
  .wworks__note-badge svg { width: 22px; height: 22px; }
  .wworks__note-copy strong {
    display: block; color: var(--navy); font-weight: 700;
    font-size: var(--text-card-body); line-height: 1.3;
  }
  .wworks__note-copy p {
    margin-top: 0.3rem; color: var(--text-body);
    font-size: var(--text-card-body); line-height: 1.55;
  }

  /* Three steps go straight to a single column — a 2+1 row would leave the
     third step stranded. */
  @media (max-width: 820px) {
    .wworks__grid { grid-template-columns: 1fr; max-width: 380px; gap: 2.25rem; }
    .wworks__notes { grid-template-columns: 1fr; gap: 1.5rem; padding: 1.75rem; }
    .wworks__note + .wworks__note {
      border-left: 0; padding-left: 0;
      border-top: 1px solid var(--border); padding-top: 1.5rem;
    }
  }
</style>
