---
import { weightWorks, weightWorksIntro, weightWorksNotes } from '../../../data/weight';
---
<section class="section section--ivory" id="how-it-works">
  <div class="container">
    <div class="section-head reveal">
      <h2>{weightWorksIntro.title}</h2>
      <p>{weightWorksIntro.lead}</p>
    </div>

    <div class="wworks__grid reveal">
      {weightWorks.map((step) => (
        <article class="wworks__step">
          <h3>{step.title}</h3>
          <hr class="rule" />
          <p>{step.body}</p>
        </article>
      ))}
    </div>

    <div class="wworks__notes reveal">
      {weightWorksNotes.map((n) => (
        <div class="wworks__note">
          <p><strong>{n.lead}</strong> {n.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Widen the standard section header so the title fits on one line at
     desktop sizes; the lead keeps a readable measure. */
  .section-head { max-width: none; }
  .section-head p { max-width: 760px; margin-inline: auto; }

  .wworks__grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.75rem;
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }
  .wworks__step { text-align: center; display: flex; flex-direction: column; align-items: center; }
  .wworks__step h3 { font-size: var(--text-card-title); font-weight: 600; line-height: 1.2; }
  .wworks__step .rule { margin-top: 0.9rem; }
  .wworks__step p { margin-top: 0.9rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.55; }

  .wworks__notes {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
    background: #fff; border: 1px solid var(--border); border-radius: var(--radius);
    padding: 1.75rem 2rem; box-shadow: var(--shadow-sm);
  }
  .wworks__note { display: flex; align-items: center; gap: 1rem; }
  .wworks__note:first-child { border-right: 1px solid var(--border); padding-right: 1.5rem; }
  /* Notes read as blue bold copy (matching the home-page note treatment). */
  .wworks__note p { color: var(--blue); font-weight: 700; font-size: var(--text-note); line-height: 1.5; }
  .wworks__note strong { color: var(--blue); }

  @media (max-width: 1000px) { .wworks__grid { grid-template-columns: 1fr 1fr; gap: 2.25rem 1.75rem; } }
  @media (max-width: 620px) {
    .wworks__grid { grid-template-columns: 1fr; max-width: 360px; margin-inline: auto; }
    .wworks__notes { grid-template-columns: 1fr; gap: 1.25rem; }
    .wworks__note:first-child { border-right: 0; border-bottom: 1px solid var(--border); padding-right: 0; padding-bottom: 1.25rem; }
  }
</style>
