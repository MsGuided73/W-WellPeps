---
import Icon from '../../Icon.astro';
import { weightWhy, weightWhyIntro } from '../../../data/weight';
---
<section class="section" id="why">
  <div class="container">
    <div class="section-head reveal">
      <h2>{weightWhyIntro.title}</h2>
      <p>{weightWhyIntro.lead}</p>
    </div>

    <div class="wwhy__grid reveal">
      {weightWhy.map((c) => (
        <article class="card wwhy__card">
          <div class="wwhy__media"><img src={c.image} alt={c.alt} width="760" height="520" loading="lazy" /></div>
          <div class="wwhy__body">
            <span class="wwhy__icon"><Icon name={c.icon} /></span>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .wwhy__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem;
    margin-top: clamp(2rem, 3vw, 3rem);
  }
  .wwhy__card { overflow: hidden; display: flex; flex-direction: column; text-align: center; }
  .wwhy__card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .wwhy__media { aspect-ratio: 16 / 10; overflow: hidden; }
  .wwhy__media img { width: 100%; height: 100%; object-fit: cover; }
  .wwhy__body { padding: 1.75rem; display: flex; flex-direction: column; align-items: center; }
  /* Icon medallion pulled up to overlap the image / body seam. */
  .wwhy__icon {
    margin-top: -52px; position: relative; z-index: 1;
    display: inline-grid; place-items: center; width: 64px; height: 64px; border-radius: 50%;
    background: var(--bg-wellness); color: var(--blue); box-shadow: 0 0 0 5px #fff;
  }
  .wwhy__icon :global(svg) { width: 30px; height: 30px; }
  .wwhy__body h3 { margin-top: 1rem; font-size: var(--text-card-title); font-weight: 600; line-height: 1.2; }
  .wwhy__body p { margin-top: 0.9rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.55; }

  @media (max-width: 900px) {
    .wwhy__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
  }
</style>
