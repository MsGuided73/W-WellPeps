---
import Icon from '../../Icon.astro';
import { weightWhy, weightWhyIntro } from '../../../data/weight';
---
<section class="section" id="why">
  <div class="container">
    <div class="section-head reveal">
      <h2>{weightWhyIntro.title}</h2>
      <p>{weightWhyIntro.lead}</p>
    </div>

    <div class="wwhy__grid reveal">
      {weightWhy.map((c) => (
        <article class="card wwhy__card">
          <div class="wwhy__media"><img src={c.image} alt={c.alt} width="760" height="651" loading="lazy" /></div>
          <div class="wwhy__body">
            <h3>{c.title}</h3>
            <hr class="rule" />
            <p>{c.body}</p>
          </div>
        </article>
      ))}
    </div>

    <p class="wwhy__more reveal">
      <a href="/why-wellpeps" class="arrow-link">Explore all the reasons Patients choose WellPeps <Icon name="arrow-right" /></a>
    </p>
  </div>
</section>

<style>
  /* Widen the section header so the title fits on one line at desktop sizes;
     the lead keeps a readable measure. */
  .section-head { max-width: none; }
  .section-head p { max-width: 760px; margin-inline: auto; }

  .wwhy__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem;
    margin-top: clamp(2rem, 3vw, 3rem);
  }
  .wwhy__card { overflow: hidden; display: flex; flex-direction: column; text-align: center; }
  .wwhy__card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  /* Near-square window to match the source images (~1.1–1.19 ratio) so they
     render essentially uncropped. */
  .wwhy__media { aspect-ratio: 7 / 6; overflow: hidden; }
  .wwhy__media img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 25%; }
  .wwhy__body { padding: 1.75rem; display: flex; flex-direction: column; align-items: center; }
  .wwhy__body h3 { font-size: var(--text-card-title); font-weight: 600; line-height: 1.2; }
  .wwhy__body .rule { margin-top: 0.9rem; }
  .wwhy__body p { margin-top: 0.9rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.55; }

  /* Link through to the full Why WellPeps page (matches the home page). */
  .wwhy__more { text-align: center; margin-top: 2rem; }
  .wwhy__more .arrow-link { font-size: var(--text-lead); font-weight: 700; }

  @media (max-width: 900px) {
    .wwhy__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
  }
</style>
