---
import { ONBOARDING_URL } from '../../../config';
import { weightCta } from '../../../data/weight';
---
<section class="wcta">
  <!-- Mirrored CTA: photo bleeds off the LEFT edge and feathers into the
       background on its right; copy sits on the right. -->
  <img class="wcta__img" src={weightCta.image} width="1500" height="1000" alt={weightCta.alt} loading="lazy" />

  <div class="wcta__wrap">
    <div class="wcta__copy reveal">
      <h2>{weightCta.title}</h2>
      <p class="wcta__lead">{weightCta.lead}</p>
      <a href={ONBOARDING_URL} class="btn btn--primary btn--lg btn--cta wcta__btn">Start Your Free Assessment</a>
      <p class="wcta__note">{weightCta.note}</p>
    </div>
  </div>
</section>

<style>
  .wcta {
    position: relative; overflow: hidden;
    background: var(--bg-warm-cream);
    display: flex; align-items: center;
    min-height: clamp(460px, 44vw, 660px);
  }
  .wcta__img {
    position: absolute; top: 0; left: 0; bottom: 0;
    width: 56vw; height: 100%; object-fit: cover; object-position: 40% center;
    -webkit-mask-image: linear-gradient(to right, #000 48%, rgba(0,0,0,0.25) 78%, transparent 100%);
            mask-image: linear-gradient(to right, #000 48%, rgba(0,0,0,0.25) 78%, transparent 100%);
  }
  .wcta__wrap {
    position: relative; z-index: 2; width: 100%; max-width: var(--content-max);
    margin-inline: auto; padding-inline: var(--gutter);
  }
  .wcta__copy { max-width: clamp(340px, 42vw, 560px); margin-left: auto; padding-block: clamp(2.5rem, 4vw, 4.25rem); }
  .wcta__copy h2 { font-size: clamp(1.9rem, 1.2rem + 2.3vw, 3rem); font-weight: 700; letter-spacing: -0.02em; color: var(--navy); line-height: 1.1; }
  .wcta__lead { margin-top: 1.1rem; color: var(--text-body); font-size: var(--text-lead); max-width: 34ch; }
  .wcta__btn { margin-top: 1.75rem; align-self: flex-start; background: var(--navy); box-shadow: 0 8px 20px rgba(8, 43, 89, 0.22); }
  .wcta__btn:hover { background: var(--navy-deep); }
  .wcta__note { margin-top: 1rem; color: var(--text-muted); font-size: var(--text-note); }

  @media (max-width: 900px) {
    .wcta { flex-direction: column; min-height: 0; align-items: stretch; }
    .wcta__img {
      position: relative; inset: auto; width: 100%; height: clamp(260px, 60vw, 400px);
      object-position: center 30%;
      -webkit-mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
              mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
    }
    .wcta__copy { max-width: none; margin-left: 0; padding-block: 2rem 2.75rem; }
  }
</style>
