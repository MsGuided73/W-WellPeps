---
import Icon from '../Icon.astro';
import { insights } from '../../data/content';
---
<section class="section section--ivory" id="insights">
  <div class="container">
    <div class="section-head reveal">
      <h2>Wellness Learning Center</h2>
      <p>Personalized care starts with informed decisions. Explore evidence-based articles, treatment guides, and wellness education designed to help you make confident healthcare decisions.</p>
    </div>

    <div class="insights__grid reveal">
      {insights.map((a) => (
        <article class="card insight">
          <div class="insight__media"><img src={a.image} width="780" height="520" alt={a.alt} loading="lazy" /></div>
          <div class="insight__body">
            <h3>{a.title}</h3>
            <p>{a.body}</p>
            <a href={a.href} class="arrow-link">Read More <Icon name="arrow-right" /></a>
          </div>
        </article>
      ))}
    </div>

    <div class="insights__cta reveal">
      <a href="#insights-library" class="btn btn--primary btn--lg">Continue Learning</a>
      <p>Explore our growing library of wellness education and treatment resources.</p>
    </div>
  </div>
</section>

<style>
  .insights__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem;
    margin-top: clamp(1.75rem, 2.5vw, 2.75rem);
  }
  .insight { overflow: hidden; display: flex; flex-direction: column; }
  .insight:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
  .insight__media { aspect-ratio: 16 / 10; overflow: hidden; }
  .insight__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease); }
  .insight:hover .insight__media img { transform: scale(1.04); }
  .insight__body { padding: 1.6rem 1.6rem 1.8rem; display: flex; flex-direction: column; flex: 1; }
  .insight__body h3 { font-size: var(--text-card-title); font-weight: 600; line-height: 1.25; }
  .insight__body p { margin-top: 0.8rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.6; flex: 1; }
  .insight .arrow-link { margin-top: 1.3rem; }

  .insights__cta { text-align: center; margin-top: 3rem; }
  .insights__cta p { margin-top: 1rem; color: var(--text-muted); font-size: var(--text-note); }

  @media (max-width: 900px) { .insights__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; } }
</style>
