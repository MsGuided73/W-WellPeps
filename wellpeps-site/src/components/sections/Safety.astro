---
import { safety } from '../../data/content';
---
<section class="section section--cool-blue" id="safety">
  <div class="container">
    <div class="section-head reveal">
      <h2>Your Safety, Wellness & Privacy <span class="accent">Come First</span></h2>
      <p>From your provider to your medication, every step is designed to protect your health, your privacy, and your peace of mind.</p>
    </div>

    <div class="safety__grid reveal">
      {safety.map((c) => (
        <article class="card safety__card">
          <span class="medallion safety__medallion"><img src={c.img} alt="" loading="lazy" /></span>
          <h3>{c.title}</h3>
          <hr class="rule" />
          <p>{c.body}</p>
        </article>
      ))}
    </div>

    <div class="safety__bar reveal">
      <div class="safety__msg">
        <span class="safety__shield"><img src="/images/icons/saf-shield-check.png" alt="" loading="lazy" /></span>
        <div><strong>You’re in good hands.</strong><p>Our team is here to support your health journey—every step of the way.</p></div>
      </div>
      <div class="safety__divider"></div>
      <div class="safety__msg">
        <span class="safety__shield"><img src="/images/icons/saf-shield.png" alt="" loading="lazy" /></span>
        <div><strong>Trusted. Certified. Committed to You.</strong><p>Your health, privacy, and peace of mind matter most.</p></div>
      </div>
    </div>
  </div>
</section>

<style>
  .safety__grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
    margin-top: clamp(1.75rem, 2.5vw, 2.75rem);
  }
  .safety__card { padding: 2.25rem 1.6rem; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .safety__card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .safety__medallion { background: #fff; box-shadow: var(--shadow-sm); }
  .safety__card h3 { font-size: 1.15rem; font-weight: 600; margin-top: 1.3rem; line-height: 1.3; }
  .safety__card .rule { margin-top: 0.9rem; }
  .safety__card p { margin-top: 0.9rem; color: var(--text-body); font-size: var(--text-small); line-height: 1.6; }

  .safety__bar {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 2rem; align-items: center;
    background: #fff; border: 1px solid var(--border); border-radius: var(--radius);
    padding: 1.75rem 2.5rem; margin-top: 1.75rem; box-shadow: var(--shadow-sm);
  }
  .safety__msg { display: flex; gap: 1rem; align-items: flex-start; }
  .safety__shield { flex: none; }
  .safety__shield img { width: 38px; height: 38px; object-fit: contain; }
  .safety__msg strong { color: var(--blue); font-family: var(--font-sans); font-size: 1.05rem; }
  .safety__msg p { color: var(--text-body); font-size: var(--text-small); margin-top: 0.2rem; }
  .safety__divider { width: 1px; align-self: stretch; background: var(--border); }

  @media (max-width: 980px) { .safety__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 760px) {
    .safety__bar { grid-template-columns: 1fr; }
    .safety__divider { width: 100%; height: 1px; }
  }
  @media (max-width: 480px) { .safety__grid { grid-template-columns: 1fr; } }
</style>
