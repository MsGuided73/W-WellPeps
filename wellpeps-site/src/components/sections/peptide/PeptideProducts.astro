---
import PeptideCard from '../../PeptideCard.astro';
import EverythingIncludedStrip from '../../EverythingIncludedStrip.astro';
import { peptideProducts, peptideProductsIntro, peptideProductsFootnote } from '../../../data/peptide';
---
<section class="section section--gray" id="peptide-products">
  <div class="container">
    <div class="pprod__head reveal">
      <h2>{peptideProductsIntro.title}</h2>
      <p class="pprod__lead">{peptideProductsIntro.lead}</p>
    </div>

    <div class="pprod__grid reveal">
      {peptideProducts.map((product) => <PeptideCard product={product} />)}
    </div>

    <p class="pprod__foot reveal">{peptideProductsFootnote}</p>

    <EverythingIncludedStrip />
  </div>
</section>

<style>
  /* Full width so the title fits on one line at desktop sizes; the lead keeps
     a readable measure. */
  .pprod__head { text-align: center; margin-inline: auto; }
  .pprod__head h2 { font-size: var(--text-section-title); font-weight: 700; }
  /* 1000px holds the lead to three lines; it turns four below ~960px. */
  .pprod__lead { margin-top: 1rem; font-size: var(--text-lead); color: var(--text-body); max-width: 1000px; margin-inline: auto; }

  .pprod__grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.75rem;
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
    max-width: 1280px; margin-inline: auto;
  }
  .pprod__foot { text-align: center; margin-top: 2rem; color: var(--blue); font-weight: 700; font-size: var(--text-note); max-width: 760px; margin-inline: auto; }

  @media (max-width: 900px) { .pprod__grid { grid-template-columns: 1fr; max-width: 560px; } }
</style>
