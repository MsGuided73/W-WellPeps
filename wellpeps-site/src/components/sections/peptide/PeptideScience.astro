---
import { peptideScience, peptideBenefits } from '../../../data/peptide';
---
<section class="section" id="science">
  <div class="container">
    <!-- Image on the LEFT so this band alternates with the hero (image right). -->
    <div class="psci__top reveal">
      <div class="psci__media"><img src={peptideScience.image} alt={peptideScience.alt} width="820" height="560" loading="lazy" /></div>
      <div class="psci__intro">
        <h2>Modern Wellness,<br />Backed by Science</h2>
        <hr class="rule rule--left" />
        {peptideScience.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <p class="psci__benefits-title reveal">{peptideScience.benefitsTitle}</p>
    <div class="psci__grid reveal">
      {peptideBenefits.map((b) => (
        <article class="card psci__benefit">
          <div class="psci__benefit-media">
            <img src={b.image} alt={b.alt} width="760" height="520" loading="lazy" />
          </div>
          <div class="psci__benefit-body">
            <h3>{b.title}</h3>
            <p>{b.body}</p>
          </div>
        </article>
      ))}
    </div>
    <p class="psci__foot reveal">{peptideScience.footnote}</p>
  </div>
</section>

<style>
  .psci__top { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); align-items: center; }
  .psci__intro h2 { font-size: clamp(2.6rem, 1.7rem + 3.5vw, 4.3rem); font-weight: 700; line-height: 1.05; }
  .psci__intro .rule { margin-block: 1.1rem 1.5rem; }
  .psci__intro p { color: var(--text-body); font-size: var(--text-card-body); line-height: 1.6; }
  .psci__intro p + p { margin-top: 1.1rem; }
  .psci__media { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
  .psci__media img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 3 / 2; }

  .psci__benefits-title {
    text-align: center; margin-top: clamp(3rem, 5vw, 4.5rem);
    font-family: var(--font-serif); font-weight: 700; color: var(--navy);
    font-size: clamp(1.3rem, 1rem + 1.2vw, 1.9rem);
    padding-bottom: 1.25rem; border-bottom: 1px solid var(--border);
  }
  /* Image-led benefit cards (same treatment as the Hair Restoration
     "How Treatments Work" cards): photo · medallion · title · body. */
  .psci__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem; margin-top: 2rem; }
  .psci__benefit { overflow: hidden; display: flex; flex-direction: column; text-align: center; }
  .psci__benefit:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .psci__benefit-media { aspect-ratio: 16 / 10; overflow: hidden; }
  .psci__benefit-media img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
  .psci__benefit-body { padding: 1.75rem 1.6rem 2rem; display: flex; flex-direction: column; align-items: center; flex: 1; }
  .psci__benefit h3 { font-family: var(--font-serif); font-size: var(--text-card-title); font-weight: 600; color: var(--navy); line-height: 1.2; }
  .psci__benefit p { margin-top: 0.9rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.6; }

  .psci__foot { text-align: center; margin-top: 2rem; color: var(--blue); font-weight: 700; font-size: var(--text-note); }

  @media (max-width: 900px) {
    .psci__top { grid-template-columns: 1fr; }
    .psci__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
  }
  @media (max-width: 900px) and (min-width: 620px) { .psci__grid { grid-template-columns: 1fr 1fr; max-width: none; } }
</style>
