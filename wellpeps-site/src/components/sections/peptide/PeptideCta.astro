---
import { ONBOARDING_URL } from '../../../config';
import { peptideCta } from '../../../data/peptide';
---
<section class="pcta">
  <img class="pcta__img" src={peptideCta.image} width="900" height="960" alt={peptideCta.alt} loading="lazy" />

  <div class="pcta__wrap">
    <div class="pcta__copy reveal">
      <h2>{peptideCta.title}<br /><span class="accent">{peptideCta.titleAccent}</span></h2>
      <hr class="rule rule--left" />
      <p class="pcta__lead">{peptideCta.lead}</p>
      <a href={ONBOARDING_URL} class="btn btn--primary btn--lg pcta__btn">Start Your Free Assessment</a>
      <p class="pcta__note">{peptideCta.note}</p>
    </div>
  </div>
</section>

<style>
  .pcta { position: relative; overflow: hidden; background: var(--bg-soft-ivory); display: flex; align-items: center; min-height: clamp(460px, 44vw, 660px); }
  .pcta__img {
    position: absolute; top: 0; left: 0; bottom: 0; width: 52vw; height: 100%;
    object-fit: cover; object-position: 60% center;
    -webkit-mask-image: linear-gradient(to right, #000 52%, rgba(0,0,0,0.25) 80%, transparent 100%);
            mask-image: linear-gradient(to right, #000 52%, rgba(0,0,0,0.25) 80%, transparent 100%);
  }
  .pcta__wrap { position: relative; z-index: 2; width: 100%; max-width: var(--content-max); margin-inline: auto; padding-inline: var(--gutter); }
  .pcta__copy { max-width: clamp(340px, 42vw, 560px); margin-left: auto; padding-block: clamp(2.5rem, 4vw, 4.25rem); }
  .pcta__copy h2 { font-size: clamp(2rem, 1.3rem + 2.6vw, 3.4rem); font-weight: 700; letter-spacing: -0.02em; color: var(--navy); line-height: 1.08; }
  .pcta__copy .rule { margin-block: 1.25rem; }
  .pcta__lead { color: var(--text-body); font-size: var(--text-lead); max-width: 42ch; }
  .pcta__btn { margin-top: 1.75rem; align-self: flex-start; }
  .pcta__note { margin-top: 1rem; color: var(--text-muted); font-size: var(--text-note); }

  @media (max-width: 900px) {
    .pcta { flex-direction: column; min-height: 0; align-items: stretch; }
    .pcta__img {
      position: relative; inset: auto; width: 100%; height: clamp(260px, 60vw, 400px); object-position: center 30%;
      -webkit-mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
              mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
    }
    .pcta__copy { max-width: none; margin-left: 0; padding-block: 2rem 2.75rem; }
  }
</style>
