---
import Icon from '../Icon.astro';
import { programs } from '../../data/programs';
---
<section class="section section--light-blue-gray" id="programs">
  <div class="container">
    <div class="section-head reveal">
      <h2>Our Wellness Programs</h2>
      <p>Personalized care to help you look, feel, and perform your best.</p>
    </div>

    <div class="programs__grid reveal">
      {programs.map((p) => (
        <article class="card program">
          <div class="program__media">
            <img src={p.image} width="780" height="520" alt={p.imageAlt} loading="lazy" />
            {p.status === 'coming-soon' && <span class="program__badge">Coming Soon</span>}
          </div>
          <div class="program__body">
            <h3>{p.title}</h3>
            <p class="program__tagline">{p.tagline}</p>
            <hr class="rule rule--left" />
            <p class="program__blurb">{p.blurb}</p>
            <a href={p.href}
               class={`pill-link${p.status === 'coming-soon' ? ' pill-link--muted' : ''}`}>
              {p.status === 'live' ? 'Explore Program' : 'Notify Me'}
              <Icon name="arrow-right" />
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .programs__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;
    margin-top: clamp(1.75rem, 2.5vw, 2.75rem);
  }
  .program { overflow: hidden; display: flex; flex-direction: column; }
  .program:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
  /* Banner close to the guide but a touch taller so faces aren't over-cropped */
  .program__media { position: relative; aspect-ratio: 11 / 6; overflow: hidden; }
  .program__media img { width: 100%; height: 100%; object-fit: cover; object-position: center 22%; transition: transform 0.5s var(--ease); }
  .program:hover .program__media img { transform: scale(1.04); }
  .program__badge {
    position: absolute; top: 0.9rem; left: 0.9rem;
    background: rgba(8,43,89,0.9); color: #fff; font-size: var(--text-body-size); font-weight: 600;
    letter-spacing: 0.04em; text-transform: uppercase; padding: 0.35rem 0.7rem; border-radius: var(--radius-pill);
  }
  .program__body { padding: 1.6rem 1.6rem 1.7rem; display: flex; flex-direction: column; flex: 1; }
  .program__body h3 { font-size: var(--text-card-title); font-weight: 600; line-height: 1.15; }
  /* Tagline hugs the title (one group); blurb sits clearly below the pair */
  /* Tagline + CTA enlarged per the 7-9 notes. */
  .program__tagline { font-family: var(--font-serif); font-style: italic; color: var(--blue); font-weight: 700; margin-top: 0.2rem; font-size: var(--text-card-body); }
  /* Rule sits under the title+tagline pair, not between them. */
  .program__body .rule { margin-top: 0.95rem; }
  .program__blurb { margin-top: 0.95rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.6; flex: 1; }
  /* Compact CTA to match the guide's pill (less padding, smaller text) */
  .program .pill-link {
    margin-top: 1rem; align-self: flex-start;
    padding: 0.55rem 1.1rem; font-size: var(--text-note); gap: 0.45rem;
  }
  .program .pill-link svg { width: 0.95em; height: 0.95em; }

  @media (max-width: 900px) { .programs__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .programs__grid { grid-template-columns: 1fr; } }
</style>
