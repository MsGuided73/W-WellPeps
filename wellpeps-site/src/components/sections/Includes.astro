---
import Icon from '../Icon.astro';
import { includes } from '../../data/content';
---
<section class="section" id="includes">
  <div class="container">
    <div class="section-head includes__head reveal">
      <h2>Every <span class="accent">WellPeps</span> Program Includes</h2>
      <p>Transparent Pricing. Licensed Healthcare Provider Review. Ongoing Provider Support.</p>
    </div>

    <div class="includes__grid reveal">
      {includes.map((c) => (
        <article class="card includes__card">
          <span class="medallion"><img src={c.img} alt="" loading="lazy" /></span>
          <hr class="rule" />
          <h3>{c.title}</h3>
          <p>{c.body}</p>
          <a href="#" class="pill-link">Learn More <Icon name="arrow-right" /></a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Wider than the shared 760px section-head so the heading and the long
     subtext each sit on one line. Title/subtext sizes are set globally on
     .section-head so every section matches; here we only widen + no-wrap. */
  .includes__head { max-width: 68rem; }
  .includes__head h2 { white-space: nowrap; }
  .includes__head p { white-space: nowrap; }

  .includes__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;
    margin-top: clamp(1.75rem, 2.5vw, 2.75rem);
  }
  .includes__card {
    padding: 2.5rem 2rem; text-align: center;
    display: flex; flex-direction: column; align-items: center;
  }
  .includes__card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .includes__card .rule { margin-top: 1.1rem; }
  .includes__card h3 { font-size: var(--text-card-title); font-weight: 600; margin-top: 0.9rem; }
  .includes__card p { margin-top: 0.8rem; color: var(--text-body); font-size: var(--text-card-body); flex: 1; }
  .includes__card .pill-link { margin-top: 1.25rem; }
  @media (max-width: 860px) {
    .includes__grid { grid-template-columns: 1fr; }
    .includes__head h2, .includes__head p { white-space: normal; }
  }
</style>
