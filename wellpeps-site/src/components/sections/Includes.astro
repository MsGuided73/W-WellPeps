---
import Icon from '../Icon.astro';
import { includes } from '../../data/content';
---
<section class="section" id="includes">
  <div class="container">
    <div class="section-head reveal">
      <h2>Every <span class="accent">WellPeps</span> Program Includes</h2>
      <p>Transparent Pricing. Licensed Healthcare Provider Review. Ongoing Provider Support.</p>
    </div>

    <div class="includes__grid reveal">
      {includes.map((c) => (
        <article class="card includes__card">
          <span class="medallion"><img src={c.img} alt="" loading="lazy" /></span>
          <hr class="rule" />
          <h3>{c.title}</h3>
          <p>{c.body}</p>
          <a href="#" class="pill-link">Learn More <Icon name="arrow-right" /></a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .includes__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem;
    margin-top: clamp(2.5rem, 4vw, 4rem);
  }
  .includes__card {
    padding: 2rem 1.75rem; text-align: center;
    display: flex; flex-direction: column; align-items: center;
  }
  .includes__card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .includes__card .rule { margin-top: 1.1rem; }
  .includes__card h3 { font-size: var(--text-h3); font-weight: 600; margin-top: 0.9rem; }
  .includes__card p { margin-top: 0.8rem; color: var(--text-body); flex: 1; }
  .includes__card .pill-link { margin-top: 1.25rem; }
  @media (max-width: 860px) { .includes__grid { grid-template-columns: 1fr; } }
</style>
