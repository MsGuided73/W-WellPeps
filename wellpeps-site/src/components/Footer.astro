---
import { CONTACT } from '../config';

/* Global footer — rebuilt to the approved light-theme comp
   (public/images/WellPeps Footer Final DG.png).

   The footer used to be a navy panel. The comp moves it to a pale
   blue-to-white wash with navy text, a solid blue newsletter button, and a
   soft wave motif bleeding off the bottom-right corner. Colours below are
   sampled straight from the comp. */

const columns = [
  {
    heading: 'Programs',
    links: [
      { label: 'Weight Management', href: '/weight-loss' },
      { label: 'Peptide Therapies', href: '/peptides' },
      { label: 'Sexual Wellness', href: '/sexual-wellness' },
      { label: 'Hair Restoration', href: '/hair-restoration' },
      { label: 'Hormone Optimization', href: '/hormone-optimization', note: 'Coming Soon' },
      { label: 'Mental Wellness', href: '/mental-wellness', note: 'Coming Soon' },
    ],
  },
  {
    heading: 'Resources',
    links: [
      { label: 'Wellness Insights', href: '/#insights' },
      { label: 'FAQ', href: '/#faq' },
      { label: 'Treatment Process', href: '/#journey' },
      { label: 'Pricing', href: '/#includes' },
      { label: 'Patient Resources', href: '/wellness-learning-center' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About WellPeps', href: '/why-wellpeps' },
      { label: 'Our Mission', href: '#' },
      { label: 'Why WellPeps', href: '/why-wellpeps' },
      { label: 'Careers', href: '#' },
      { label: 'Contact Us', href: '#' },
    ],
  },
  {
    heading: 'Support',
    links: [
      { label: 'Help Center', href: '#' },
      { label: 'Virtual Assistant', href: '#' },
      { label: 'Shipping & Delivery', href: '/#faq' },
      { label: 'Privacy & Security', href: '/#safety' },
    ],
  },
];

const legal = [
  'Privacy Policy', 'Terms of Use', 'Notice of Privacy Practices',
  'Accessibility', 'Do Not Sell or Share My Personal Information',
];
---
<footer class="footer">
  <!-- Wave motif: bleeds off the bottom-right, sits behind all content. -->
  <svg class="footer__wave" viewBox="0 0 1440 260" preserveAspectRatio="none" aria-hidden="true" focusable="false">
    <path d="M0 214C240 214 420 176 690 140s470-64 750-90v210H0Z" fill="#CFE0FA" opacity="0.55" />
    <path d="M0 250C260 250 430 214 700 180s500-58 740-78v158H0Z" fill="#BDD4F6" opacity="0.5" />
  </svg>

  <div class="container-wide footer__inner">
    <!-- Brand + newsletter -->
    <div class="footer__top">
      <div class="footer__brand">
        <img src="/images/logo-full.png" alt="WellPeps" class="footer__logo" width="600" height="125" />
      </div>

      <form class="newsletter" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <p class="visually-hidden"><label>Leave blank: <input name="bot-field" /></label></p>
        <div class="newsletter__row">
          <div class="newsletter__field">
            <svg class="newsletter__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path fill="currentColor" d="M3 6.5A1.5 1.5 0 0 1 4.5 5h15A1.5 1.5 0 0 1 21 6.5v.3l-9 5.6-9-5.6v-.3Zm0 2.65V17.5A1.5 1.5 0 0 0 4.5 19h15a1.5 1.5 0 0 0 1.5-1.5V9.15l-8.47 5.28a1 1 0 0 1-1.06 0L3 9.15Z" />
            </svg>
            <input type="email" name="email" required placeholder="Enter your email address" aria-label="Email address" />
          </div>
          <button type="submit" class="newsletter__btn">Get Free Wellness Tips Monthly</button>
        </div>
        <p class="newsletter__note">
          <svg class="newsletter__lock" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M12 2.5A4.5 4.5 0 0 0 7.5 7v2.5H7A2 2 0 0 0 5 11.5v7A2 2 0 0 0 7 20.5h10a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-.5V7A4.5 4.5 0 0 0 12 2.5Zm2.5 7h-5V7a2.5 2.5 0 0 1 5 0v2.5Z" />
          </svg>
          One email each month. No spam. Unsubscribe anytime.
        </p>
      </form>
    </div>

    <hr class="footer__rule" />

    <!-- Link columns -->
    <div class="footer__grid">
      {columns.map((col) => (
        <div class="footer__col">
          <h4>{col.heading}</h4>
          <ul>
            {col.links.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
                {l.note && <span class="footer__soon">{l.note}</span>}
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="footer__col footer__contact">
        <h4>Contact Us</h4>
        <ul>
          <li>
            <svg class="footer__cicon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path fill="currentColor" d="M6.6 3h-.4A3.2 3.2 0 0 0 3 6.2c0 8.2 6.6 14.8 14.8 14.8a3.2 3.2 0 0 0 3.2-3.2v-.4a1.4 1.4 0 0 0-1-1.35l-3.4-1a1.4 1.4 0 0 0-1.45.44l-1 1.2a11.6 11.6 0 0 1-5.1-5.1l1.2-1a1.4 1.4 0 0 0 .44-1.45l-1-3.4A1.4 1.4 0 0 0 6.6 3Z" />
            </svg>
            <span>
              <a href={CONTACT.phoneHref}>{CONTACT.phone}</a>
              <small>{CONTACT.hours}</small>
            </span>
          </li>
          <li>
            <svg class="footer__cicon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path fill="currentColor" d="M3 6.5A1.5 1.5 0 0 1 4.5 5h15A1.5 1.5 0 0 1 21 6.5v.3l-9 5.6-9-5.6v-.3Zm0 2.65V17.5A1.5 1.5 0 0 0 4.5 19h15a1.5 1.5 0 0 0 1.5-1.5V9.15l-8.47 5.28a1 1 0 0 1-1.06 0L3 9.15Z" />
            </svg>
            <span><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></span>
          </li>
          <li>
            <svg class="footer__cicon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path fill="currentColor" d="M12 2.5a7 7 0 0 0-7 7c0 5.1 6.1 11.6 6.36 11.87a.88.88 0 0 0 1.28 0C12.9 21.1 19 14.6 19 9.5a7 7 0 0 0-7-7Zm0 9.6a2.6 2.6 0 1 1 0-5.2 2.6 2.6 0 0 1 0 5.2Z" />
            </svg>
            <span>Licensed Providers<br />in All 50 States</span>
          </li>
        </ul>
      </div>
    </div>

    <hr class="footer__rule footer__rule--legal" />

    <ul class="footer__legal">
      {legal.map((l) => <li><a href="#">{l}</a></li>)}
    </ul>

    <div class="footer__bottom">
      <div class="footer__legalese">
        <p class="footer__disclaimer">
          WellPeps is a platform that connects patients with licensed healthcare providers and pharmacy partners.
          Medical services are provided by independent providers. WellPeps does not provide medical advice,
          diagnosis, or treatment.
        </p>
        <p class="footer__copy">© 2025 WellPeps. All rights reserved.</p>
      </div>

      <div class="footer__badges">
        <span class="footer__badge">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M12 2.6 4.8 5.5v5.8c0 4.7 3.05 8.35 7.2 10.1 4.15-1.75 7.2-5.4 7.2-10.1V5.5L12 2.6Z" fill="none" stroke="currentColor" stroke-width="1.6" />
            <path fill="currentColor" d="M12 7.6a2.5 2.5 0 0 0-2.5 2.5v.7h-.3a1 1 0 0 0-1 1v3.1a1 1 0 0 0 1 1h5.6a1 1 0 0 0 1-1v-3.1a1 1 0 0 0-1-1h-.3v-.7A2.5 2.5 0 0 0 12 7.6Zm1.2 3.2h-2.4v-.7a1.2 1.2 0 0 1 2.4 0v.7Z" />
          </svg>
          <span class="footer__badge-text">HIPAA<br />Compliant</span>
        </span>

        <span class="footer__badge-divider" aria-hidden="true"></span>

        <span class="footer__badge">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M12 2.6 4.8 5.5v5.8c0 4.7 3.05 8.35 7.2 10.1 4.15-1.75 7.2-5.4 7.2-10.1V5.5L12 2.6Z" fill="none" stroke="currentColor" stroke-width="1.6" />
            <path d="m8.7 11.9 2.4 2.4 4.2-4.6" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="footer__badge-text">LegitScript<br />Certified</span>
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Palette sampled from the approved comp. Scoped to the footer so the
     global tokens (which describe the navy footer this replaced) stay put. */
  .footer {
    --f-blue: #1C60D3;        /* headings, icons, newsletter button */
    --f-blue-hover: #1350B8;
    --f-navy: #0A1C46;        /* link + badge text */
    --f-muted: #5A6A8A;       /* hours, disclaimer, copyright */
    --f-rule: rgba(28, 96, 211, 0.14);

    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: linear-gradient(180deg, #F8FAFE 0%, #F3F7FD 42%, #E7F0FD 76%, #DEE9FC 100%);
    color: var(--f-navy);
    padding-block: clamp(3rem, 2rem + 4vw, 4.5rem) 2.5rem;
    font-size: var(--text-footer);
  }
  .footer__inner { position: relative; z-index: 1; }

  .footer__wave {
    position: absolute; inset: auto 0 0 0; z-index: 0;
    width: 100%; height: clamp(140px, 18vw, 260px);
    pointer-events: none;
  }

  .footer a { color: var(--f-navy); transition: color var(--dur) var(--ease); }
  .footer a:hover { color: var(--f-blue); }

  /* ---- Brand + newsletter ---- */
  .footer__top {
    display: grid; grid-template-columns: 1fr 1.35fr; gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .footer__logo { width: clamp(260px, 30vw, 460px); height: auto; display: block; }

  .newsletter__row {
    display: flex; background: #fff;
    border: 1px solid #DCE6F5; border-radius: 14px; overflow: hidden;
    box-shadow: 0 1px 2px rgba(10, 28, 70, 0.05);
  }
  .newsletter__field { display: flex; align-items: center; gap: 0.75rem; flex: 1; padding: 0 1.15rem; }
  .newsletter__icon { width: 24px; height: 24px; color: var(--f-navy); flex: none; }
  .newsletter__field input {
    flex: 1; background: none; border: 0; color: var(--f-navy); font-family: var(--font-sans);
    font-size: var(--text-body-size); padding: 1.05rem 0; min-width: 0;
  }
  .newsletter__field input::placeholder { color: #7B8AA6; }
  .newsletter__field input:focus { outline: none; }
  .newsletter__btn {
    border: 0; cursor: pointer; border-radius: 12px;
    background: var(--f-blue); color: #fff;
    font-family: var(--font-sans); font-weight: 700; font-size: var(--text-body-size); line-height: 1.25;
    padding: 0.95rem 1.9rem; white-space: nowrap;
    transition: background var(--dur) var(--ease);
  }
  .newsletter__btn:hover { background: var(--f-blue-hover); }
  .newsletter__note {
    display: flex; align-items: center; gap: 0.5rem;
    color: var(--f-navy); margin-top: 0.85rem;
  }
  .newsletter__lock { width: 18px; height: 18px; color: var(--f-navy); flex: none; }

  /* ---- Rules ---- */
  .footer__rule { border: 0; height: 1px; background: var(--f-rule); margin: 2.5rem 0; }
  .footer__rule--legal { margin: 2.5rem 0 1.6rem; }

  /* ---- Link columns ----
     The comp gives Programs a little extra room (it carries the longest
     labels), so the first column is weighted slightly wider than the rest. */
  .footer__grid {
    display: grid; grid-template-columns: 1.1fr 1fr 1fr 1fr 1.05fr; gap: 2rem;
  }
  .footer__col h4 {
    font-family: var(--font-sans); font-weight: 700; font-size: var(--text-body-size);
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--f-blue); margin-bottom: 1.4rem;
  }
  .footer__col ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .footer__soon {
    display: block; margin-top: 0.15rem;
    font-size: var(--text-legal); color: var(--f-blue);
  }

  .footer__contact ul li { display: flex; gap: 0.7rem; align-items: flex-start; line-height: 1.4; }
  .footer__cicon { width: 22px; height: 22px; color: var(--f-blue); margin-top: 1px; flex: none; }
  .footer__contact small { display: block; margin-top: 0.2rem; font-size: var(--text-legal); color: var(--f-muted); }

  /* ---- Legal links ---- */
  .footer__legal {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; align-items: center;
  }
  .footer__legal li { display: flex; align-items: center; }
  .footer__legal li + li::before {
    content: ''; width: 1px; height: 1.05em;
    background: rgba(10, 28, 70, 0.22); margin-inline: 1.25rem;
  }
  .footer__legal a { color: var(--f-navy); font-size: var(--text-legal); }

  /* ---- Disclaimer + trust badges ----
     The comp centres the legalese in the space left of the badges rather
     than on the full container, so the text block flexes and the badges
     hold the right edge. */
  .footer__bottom {
    display: flex; align-items: flex-end; gap: 2rem;
    margin-top: 1.8rem;
  }
  .footer__legalese { flex: 1; min-width: 0; }
  .footer__disclaimer {
    color: var(--f-muted); font-size: var(--text-legal); line-height: 1.65;
    text-align: center; max-width: 62ch; margin: 0 auto;
  }
  .footer__copy { text-align: center; color: var(--f-muted); font-size: var(--text-legal); margin-top: 1.1rem; }

  .footer__badges { display: flex; align-items: center; gap: 1.25rem; flex: none; }
  .footer__badge { display: inline-flex; align-items: center; gap: 0.6rem; color: var(--f-navy); }
  .footer__badge svg { width: 34px; height: 34px; flex: none; }
  .footer__badge-text {
    font-weight: 700; font-size: var(--text-legal); line-height: 1.2;
    letter-spacing: 0.03em; text-transform: uppercase;
  }
  .footer__badge-divider { width: 1px; align-self: stretch; background: rgba(10, 28, 70, 0.2); }

  @media (max-width: 1100px) {
    .footer__grid { grid-template-columns: repeat(3, 1fr); gap: 2.25rem 1.5rem; }
  }
  @media (max-width: 900px) {
    .footer__top { grid-template-columns: 1fr; }
    .footer__bottom { flex-direction: column; align-items: center; gap: 1.75rem; }
  }
  @media (max-width: 640px) {
    .newsletter__row { flex-direction: column; }
    .newsletter__btn { border-radius: 0; text-align: center; white-space: normal; }
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__legal { flex-direction: column; align-items: flex-start; gap: 0.85rem; }
    .footer__legal li + li::before { display: none; }
    .footer__badges { flex-wrap: wrap; justify-content: center; }
  }
</style>
