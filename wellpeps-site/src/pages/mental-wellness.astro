---
import BaseLayout from '../layouts/BaseLayout.astro';
import WaitlistSection from '../components/sections/WaitlistSection.astro';
---
<BaseLayout
  title="Mental Wellness (Coming Soon) — WellPeps"
  description="Personalized mental wellness support is coming soon to WellPeps. Join the priority list for early access to care and resources for your mind and well-being."
>
  <WaitlistSection
    eyebrowIcon="brain"
    titleLead="Mental Wellness."
    titleAccent="Coming Soon."
    subhead="Personalized Support for a Healthier, Happier You"
    lead="Be among the first to know when our mental wellness programs are available. Get early access to personalized care and resources designed to support your mind and well-being."
    image="/images/mental/woman.png"
    imageAlt="A woman sitting peacefully on a coastal hillside at sunset"
    imageWidth={844}
    imageHeight={948}
    successBody="Thanks for your interest. We’ll email you the moment mental wellness enrollment opens."
  />
</BaseLayout>
