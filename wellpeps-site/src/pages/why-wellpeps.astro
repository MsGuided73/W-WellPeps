---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { ONBOARDING_URL } from '../config';

/* Copy for both card sections is verbatim from the approved "Why WellPeps
   Page 7-9 Notes"; icons follow the client's icon sheet. */
const trustCards = [
  { icon: 'stethoscope', title: 'Physician & Pharmacy Founded', body: 'Built by healthcare professionals dedicated to making personalized wellness more accessible, convenient, and patient-centered.' },
  { icon: 'caduceus', title: 'Decades of Healthcare Experience', body: 'Our founders, physicians and pharmacy partners bring decades of clinical experience to every patient journey.' },
  { icon: 'map-check', title: '50-State Licensed Provider Network', body: 'Access licensed healthcare providers serving patients across all 50 states where available.' },
  { icon: 'flask-search', title: 'Access to Leading Labs', body: 'Convenient access to trusted national laboratory partners, including Quest Diagnostics® and Labcorp®, when clinically appropriate.' },
  { icon: 'pharmacy', title: 'Medications from USA Pharmacies', body: 'Medications are dispensed through licensed U.S. pharmacy partners that meet applicable quality and regulatory standards.' },
  { icon: 'legit-badge', title: 'LegitScript Certified', body: 'LegitScript certification reflects our commitment to transparency, compliance, and patient protection.' },
];

const patientsFirstCards = [
  { icon: 'clipboard-check', title: 'Personalized Care', body: 'Every treatment plan is tailored by licensed providers to your unique health history, goals, and needs.' },
  { icon: 'headset', title: 'Ongoing Support', body: 'Providers are available to guide, monitor, and support your treatment every step of the way.' },
  { icon: 'price-shield', title: 'Transparent Pricing', body: 'Know your program cost upfront with clear pricing and no hidden fees or surprise charges.' },
  { icon: 'clock-x', title: 'Cancel Anytime', body: 'You’re never locked into a long-term commitment—cancel anytime before your next month’s medication is ordered.' },
  { icon: 'no-insurance', title: 'No Insurance Required', body: 'Affordable self-pay programs make personalized wellness care simple and accessible without insurance.' },
  { icon: 'lock', title: 'Privacy Protected', body: 'Your personal health information is protected using secure technology and HIPAA-compliant safeguards.' },
];

/* New FAQ section — copy verbatim from the 7-9 notes. */
const faqs = [
  { q: 'Why choose WellPeps instead of another telehealth company?', a: 'WellPeps combines physician-guided care, experienced pharmacy partners, personalized treatment plans, transparent pricing, and ongoing support to deliver a more patient-centered healthcare experience.' },
  { q: 'Are your healthcare providers licensed?', a: 'Yes. Every treatment recommendation is made by licensed healthcare providers practicing in the states where they are authorized to provide care.' },
  { q: 'Where do your medications come from?', a: 'When prescribed, medications are dispensed through licensed U.S. pharmacy partners that meet applicable quality and regulatory standards.' },
  { q: 'Is my personal health information secure?', a: 'Yes. We use HIPAA-compliant systems and secure technology to protect your privacy and personal health information.' },
  { q: 'Can I cancel my membership at any time?', a: 'Yes. Patients may cancel anytime and request a refund, except for medications that have already been ordered or processed for that month’s shipment.' },
  { q: 'Do I need insurance?', a: 'No. WellPeps offers straightforward self-pay pricing, so insurance is not required to receive care.' },
];
---
<BaseLayout
  title="Why WellPeps — Personalized, Provider-Guided Wellness"
  description="WellPeps was founded by a physician and pharmacy professionals to make personalized wellness more accessible—combining licensed providers, trusted pharmacy partners, and evidence-based treatments in one seamless experience."
>
  <!-- Intro / founding story -->
  <section class="section why-intro">
    <div class="container why-intro__inner">
      <div class="why-intro__copy reveal">
        <h1>Why we Founded<br /><span class="accent">WellPeps</span></h1>
        <hr class="rule rule--left" />
        <p class="why-intro__subhead">We believe healthcare should be more convenient, more accessible and more personal.</p>
        <p>Healthcare has never offered more opportunities to help people live healthier lives. Yet for many patients, getting the right care still means long wait times, confusing treatment options, rushed appointments, and little ongoing support.</p>
        <p>WellPeps was founded by a physician and experienced pharmacy professionals who believed there should be a better way.</p>
        <p>Today, WellPeps combines physician-guided care, licensed providers, trusted pharmacy partners, and evidence-based treatments to help patients nationwide access personalized wellness from home.</p>
        <p class="why-intro__closer">Because healthcare should feel personal again.</p>
      </div>
      <div class="why-intro__media reveal">
        <img src="/images/about/hero.webp" width="900" height="1000" alt="A WellPeps patient enjoying life outdoors" fetchpriority="high" />
      </div>
    </div>
  </section>

  <!-- Why Patients Trust WellPeps -->
  <section class="section section--pale-blue">
    <div class="container">
      <div class="section-head reveal"><h2>Why Patients Trust WellPeps</h2></div>
      <div class="why-cards reveal">
        {trustCards.map((c) => (
          <article class="card why-card">
            <h3>{c.title}</h3>
            <hr class="rule" />
            <p>{c.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- We Put Patients First -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal"><h2>We Put Patients First</h2></div>
      <div class="why-cards reveal">
        {patientsFirstCards.map((c) => (
          <article class="card why-card">
            <h3>{c.title}</h3>
            <hr class="rule" />
            <p>{c.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Modern Healthcare, Built Around You -->
  <section class="section section--sky">
    <div class="container why-built__inner">
      <div class="why-built__media reveal">
        <img src="/images/about/built-around-you.webp" width="820" height="620" alt="A woman relaxing on the beach with a water bottle" loading="lazy" />
      </div>
      <div class="why-built__copy reveal">
        <h2>Modern Healthcare,<br />Built Around You</h2>
        <hr class="rule rule--left" />
        <p>Instead of feeling like another online healthcare platform, WellPeps was designed to provide a more connected experience—from your initial consultation through ongoing care and support.</p>
        <p>Our goal isn’t simply to provide treatment—it’s to help you make informed decisions about your long-term health with trusted medical guidance every step of the way, in a way that’s simple, transparent and convenient.</p>
      </div>
    </div>
  </section>

  <!-- Our Promise — copy left, photo opposite (per the 7-9 notes) -->
  <section class="section">
    <div class="container why-promise">
      <div class="why-promise__copy reveal">
        <h2>Our Promise</h2>
        <hr class="rule rule--left" />
        <p>We’re honored every time a patient chooses WellPeps.</p>
        <p>That trust is something we work to earn every day through personalized care, transparent communication, and a commitment to helping people feel their very best.</p>
        <p>Whether you’re taking your first step toward better wellness or continuing a journey you’ve already begun, we’re here to support you.</p>
      </div>
      <div class="why-promise__media reveal">
        <img src="/images/about/our-promise.webp" width="1536" height="1024" alt="The WellPeps promise — personalized, provider-guided wellness care" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Common Questions -->
  <section class="section section--pale-blue" id="faq">
    <div class="container">
      <div class="section-head reveal"><h2>Common Questions</h2></div>
      <div class="why-faq reveal">
        {faqs.map((f, i) => (
          <div class="why-faq__item" data-faq>
            <button type="button" aria-expanded={i === 0 ? 'true' : 'false'}>
              {f.q}
              <span class="why-faq__icon"><Icon name="chevron-down" /></span>
            </button>
            <div class="why-faq__panel"><p>{f.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — same full-bleed band as the category-page CTAs: photo bleeds off
       the right edge and feathers into the ivory background on its left. -->
  <section class="why-cta">
    <img class="why-cta__img" src="/images/about/cta-couple.webp" width="888" height="875"
         alt="A couple walking together through a sunny park" loading="lazy" />
    <div class="why-cta__wrap">
      <div class="why-cta__copy reveal">
        <h2>Ready to Start Your<br />Wellness Journey?</h2>
        <p class="why-cta__lead">Find the wellness program that’s right for you.</p>
        <a href="/#programs" class="btn btn--primary btn--lg btn--cta why-cta__btn">Explore Programs <Icon name="arrow-right" /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Intro. The headline must break only at its explicit <br> — "Why we Founded"
     on line 1, "WellPeps" on line 2 — so it is sized in cqw against the copy
     column rather than in vw. Viewport units let it outgrow the column and wrap
     to a third line at mid-desktop widths. */
  .why-intro__inner { display: grid; grid-template-columns: 1.05fr 0.95fr; align-items: center; gap: clamp(2rem, 4vw, 3.5rem); }
  .why-intro__copy { container-type: inline-size; max-width: 760px; }
  .why-intro__copy h1 { font-size: clamp(2.5rem, 11.5cqw, 5rem); font-weight: 700; letter-spacing: -0.02em; color: var(--navy); line-height: 1.02; }
  .why-intro__subhead { margin-top: 1.5rem; font-family: var(--font-serif); font-weight: 700; font-size: clamp(1.3rem, 1.05rem + 1vw, 1.8rem); color: var(--navy); line-height: 1.3; }
  .why-intro__copy p:not(.why-intro__subhead):not(.why-intro__closer) { margin-top: 1rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.7; }
  .why-intro__closer { margin-top: 1.4rem; font-family: var(--font-serif); font-weight: 700; color: var(--navy); font-size: var(--text-lead); }
  .why-intro__media { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
  /* Match the provided group photo's 3:2 ratio so no one is cropped out. */
  .why-intro__media img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 3 / 2; }

  /* Widen the standard section headers so titles ("Why Patients Choose
     WellPeps") fit on one line at desktop sizes. */
  .section-head { max-width: none; }

  /* Cards */
  .why-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem; margin-top: clamp(2rem, 3vw, 2.75rem); }
  .why-card { padding: 2.5rem 2rem; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .why-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .why-card h3 { font-size: var(--text-card-title); font-weight: 600; color: var(--navy); line-height: 1.2; }
  .why-card .rule { margin-top: 1rem; }
  .why-card p { margin-top: 1rem; color: var(--text-body); font-size: var(--text-card-body); line-height: 1.6; }

  /* FAQ accordion (same behaviour as the program-page FAQs). */
  .why-faq { max-width: 860px; margin-inline: auto; display: flex; flex-direction: column; gap: 0.9rem; margin-top: clamp(2rem, 3vw, 2.75rem); }
  .why-faq__item { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .why-faq__item:hover { box-shadow: var(--shadow); }
  .why-faq__item button {
    width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    background: none; border: 0; cursor: pointer; text-align: left; padding: 1.35rem 1.5rem;
    font-family: var(--font-sans); font-weight: 700; font-size: var(--text-faq-q); color: var(--navy); line-height: 1.35;
  }
  .why-faq__icon { display: grid; place-items: center; width: 28px; height: 28px; flex: none; color: var(--blue); transition: transform var(--dur) var(--ease); }
  .why-faq__icon :global(svg) { width: 22px; height: 22px; }
  .why-faq__item button[aria-expanded='true'] .why-faq__icon { transform: rotate(180deg); }
  .why-faq__panel { display: grid; grid-template-rows: 0fr; transition: grid-template-rows var(--dur) var(--ease); }
  .why-faq__panel > p { overflow: hidden; color: var(--text-body); padding: 0 1.5rem; font-size: var(--text-faq-a); line-height: 1.65; }
  .why-faq__item button[aria-expanded='true'] + .why-faq__panel { grid-template-rows: 1fr; }
  .why-faq__item button[aria-expanded='true'] + .why-faq__panel > p { padding-bottom: 1.4rem; }

  /* Built Around You */
  .why-built__inner { display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: clamp(2rem, 5vw, 4rem); }
  .why-built__media { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
  .why-built__media img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4 / 3.2; }
  .why-built__copy h2 { font-size: var(--text-section-title); font-weight: 700; line-height: 1.08; }
  .why-built__copy .rule { margin-block: 1.1rem 1.4rem; }
  .why-built__copy p { color: var(--text-body); font-size: var(--text-card-body); line-height: 1.65; }
  .why-built__copy p + p { margin-top: 1rem; }

  /* Our Promise — copy left, photo right */
  .why-promise { display: grid; grid-template-columns: 1.05fr 0.95fr; align-items: center; gap: clamp(2rem, 4vw, 4rem); }
  .why-promise__media { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
  .why-promise__media img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4 / 3; }
  .why-promise__copy h2 { font-size: var(--text-section-title); font-weight: 700; }
  .why-promise__copy .rule { margin-block: 1rem 1.4rem; }
  .why-promise__copy p { color: var(--text-body); font-size: var(--text-card-body); line-height: 1.65; }
  .why-promise__copy p + p { margin-top: 0.9rem; }

  /* CTA — full-bleed band, photo right, feathered left (matches category CTAs). */
  .why-cta {
    position: relative; overflow: hidden; background: var(--bg-soft-ivory);
    display: flex; align-items: center;
    min-height: clamp(560px, 52vw, 800px);
  }
  .why-cta__img {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: 56vw; height: 100%;
    object-fit: cover; object-position: center 20%;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.55) 20%, #000 38%);
            mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.55) 20%, #000 38%);
  }
  .why-cta__wrap {
    position: relative; z-index: 2; width: 100%; max-width: var(--content-max);
    margin-inline: auto; padding-inline: var(--gutter);
  }
  .why-cta__copy { max-width: clamp(340px, 44vw, 580px); padding-block: clamp(2.5rem, 4vw, 4.25rem); }
  .why-cta__copy h2 { font-size: clamp(2.1rem, 1.3rem + 3vw, 3.6rem); font-weight: 700; letter-spacing: -0.02em; color: var(--navy); line-height: 1.08; }
  /* 34ch clipped this sentence 4px short of fitting and stranded "you." on its
     own line. Measured one-line width is 484px (~35ch); 38ch leaves headroom
     without exceeding the 580px copy column. */
  .why-cta__lead { margin-top: 1.1rem; color: var(--text-body); font-size: var(--text-lead); max-width: 38ch; }
  .why-cta__btn { margin-top: 1.75rem; align-self: flex-start; background: var(--navy); box-shadow: 0 8px 20px rgba(8, 43, 89, 0.22); }
  .why-cta__btn:hover { background: var(--navy-deep); }

  @media (max-width: 1000px) {
    .why-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 900px) {
    .why-intro__inner { grid-template-columns: 1fr; }
    /* Stacked, the copy column spans the full container, so the cqw-based
       headline would balloon. Hold it near its previous stacked size. */
    .why-intro__copy h1 { font-size: clamp(2rem, 12cqw, 3.9rem); }
    .why-intro__media { order: -1; }
    .why-intro__media img { aspect-ratio: 3 / 2; }
    .why-cards { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
    .why-built__inner { grid-template-columns: 1fr; }
    .why-built__media { order: -1; }
    .why-promise { grid-template-columns: 1fr; }
    .why-promise__media { order: -1; }
    .why-cta { flex-direction: column; min-height: 0; align-items: stretch; }
    .why-cta__img {
      position: relative; inset: auto; width: 100%; height: clamp(260px, 60vw, 400px);
      object-position: center 25%;
      -webkit-mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
              mask-image: linear-gradient(to bottom, #000 62%, transparent 100%);
    }
    .why-cta__copy { max-width: none; padding-block: 2rem 2.75rem; }
  }
</style>
