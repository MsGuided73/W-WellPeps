---
/**
 * Wellness Learning Center — hub.
 *
 * Follows the approved landing mockup: hero with a photo collage and trust
 * markers, article search, a hand-picked Featured row, then the full library
 * as collapsible category rows.
 *
 * The library is rendered as accordions rather than six long stacked grids so
 * the whole catalogue is scannable in one screen — with 45 articles the flat
 * layout pushed the last categories well below the fold. Every article link is
 * in the HTML regardless of open/closed state, so search engines still see the
 * full library and the page works without JavaScript (details/summary).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { ONBOARDING_URL } from '../../config';
import { getCategoriesWithArticles, getFeaturedArticles, categoryIcon } from '../../lib/blog';

const categories = await getCategoriesWithArticles();
const featured = await getFeaturedArticles();
const totalArticles = categories.reduce((n, c) => n + c.articles.length, 0);

const trustMarkers = [
  { icon: 'shield-check', label: 'Physician\nReviewed' },
  { icon: 'lock', label: 'Trusted\nInformation' },
  { icon: 'user-check', label: 'Personalized\nApproach' },
];

// Flat index for the client-side search box.
const searchIndex = categories.flatMap((c) =>
  c.articles.map((a) => ({
    t: a.title,
    d: a.meta_description ?? '',
    c: c.name,
    u: a.url_path,
    m: a.reading_minutes,
  }))
);
---

<BaseLayout
  title="Wellness Learning Center | WellPeps"
  description="A growing library of physician-reviewed educational resources on weight management, sexual wellness, hair restoration, peptide therapies, and everyday wellness."
>
  <section class="lc-hero">
    <div class="container lc-hero__inner">
      <div class="lc-hero__text">
        <h1 class="lc-hero__title">Wellness<br />Learning Center</h1>
        <p class="lc-hero__lede">
          A growing library of physician-reviewed educational resources to help
          you make informed decisions about your health and wellness.
        </p>
        <ul class="lc-trust">
          {trustMarkers.map((m) => (
            <li>
              <Icon name={m.icon} />
              <span>{m.label}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="lc-collage">
        <img
          class="lc-collage__main"
          src="/images/learning-center/couple.webp"
          alt="" width="1400" height="933" loading="eager" fetchpriority="high"
        />
        <img
          class="lc-collage__top"
          src="/images/learning-center/hub-hero.webp"
          alt="" width="1254" height="1254" loading="eager"
        />
        <img
          class="lc-collage__bottom"
          src="/images/learning-center/consult.webp"
          alt="" width="900" height="900" loading="eager"
        />
      </div>
    </div>
  </section>

  <div class="container lc-body">
    <form class="lc-search" role="search" onsubmit="return false">
      <Icon name="search" />
      <label class="sr-only" for="lc-q">Search articles</label>
      <input
        id="lc-q" type="search" placeholder="Search articles…"
        autocomplete="off" data-search
      />
    </form>

    <!-- Search results replace the featured + library sections while typing. -->
    <section class="lc-results" data-results hidden aria-live="polite">
      <h2 class="lc-results__title" data-results-title></h2>
      <ul class="lc-results__list" data-results-list></ul>
    </section>

    <div data-browse>
      {featured.length > 0 && (
        <section class="lc-featured" aria-labelledby="featured-h">
          <header class="lc-featured__head">
            <h2 id="featured-h"><Icon name="star" />Featured Articles</h2>
            <a class="lc-featured__all" href="#library">
              View all articles <Icon name="arrow-right" />
            </a>
          </header>

          <ul class="lc-featured__grid">
            {featured.map((a) => (
              <li>
                <a class="lc-fcard" href={a.url_path}>
                  <span class="lc-fcard__icon"><Icon name={categoryIcon(a.category.slug)} /></span>
                  <span class="lc-fcard__cat">{a.category.name}</span>
                  <span class="lc-fcard__title">{a.title}</span>
                  {a.meta_description && <span class="lc-fcard__desc">{a.meta_description}</span>}
                  <span class="lc-fcard__meta">
                    <Icon name="clock" />{a.reading_minutes} min read
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="lc-library" id="library" aria-label="Browse all articles">
        {categories.map((category) => (
          <details class="lc-cat" name="lc-library">
            <summary class="lc-cat__row">
              <span class="lc-cat__icon"><Icon name={categoryIcon(category.slug)} /></span>
              <span class="lc-cat__text">
                <span class="lc-cat__name">{category.name}</span>
                {category.description && (
                  <span class="lc-cat__desc">{category.description}</span>
                )}
              </span>
              <span class="lc-cat__count">
                {category.articles.length} {category.articles.length === 1 ? 'Article' : 'Articles'}
              </span>
              <span class="lc-cat__chev"><Icon name="chevron-down" /></span>
            </summary>

            <ul class="lc-cat__list">
              {category.articles.map((a) => (
                <li>
                  <a href={a.url_path}>
                    <span class="lc-cat__link-title">{a.title}</span>
                    <span class="lc-cat__link-meta">{a.reading_minutes} min</span>
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))}
      </section>
    </div>

    <section class="lc-cta">
      <img class="lc-cta__mark" src="/images/w-mark.png" alt="" width="72" height="72" loading="lazy" />
      <div class="lc-cta__text">
        <h2>Personalized care starts with the right medical evaluation.</h2>
        <p>
          Complete an assessment and a licensed healthcare provider will review
          your information to determine the best next steps for your wellness journey.
        </p>
      </div>
      <a href={ONBOARDING_URL} class="btn btn--primary lc-cta__btn">
        Start Free Assessment
      </a>
    </section>

    <p class="lc-disclaimer">
      Information on this site is for educational purposes only and is not a
      substitute for professional medical advice, diagnosis, or treatment.
      {totalArticles} articles across {categories.length} topics.
    </p>
  </div>
</BaseLayout>

<script is:inline define:vars={{ searchIndex }}>
  (() => {
    const input = document.querySelector('[data-search]');
    const browse = document.querySelector('[data-browse]');
    const results = document.querySelector('[data-results]');
    const list = document.querySelector('[data-results-list]');
    const title = document.querySelector('[data-results-title]');
    if (!input || !browse || !results || !list || !title) return;

    const esc = (s) =>
      s.replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]
      );

    const render = (q) => {
      const terms = q.toLowerCase().split(/\s+/).filter(Boolean);
      if (!terms.length) {
        results.hidden = true;
        browse.hidden = false;
        return;
      }
      // Every term must appear somewhere in the title, description or category,
      // so extra words narrow the result set rather than widening it.
      const hits = searchIndex.filter((a) => {
        const hay = `${a.t} ${a.d} ${a.c}`.toLowerCase();
        return terms.every((t) => hay.includes(t));
      });

      browse.hidden = true;
      results.hidden = false;
      title.textContent = hits.length
        ? `${hits.length} ${hits.length === 1 ? 'article' : 'articles'} matching “${q}”`
        : `No articles matching “${q}”`;
      list.innerHTML = hits
        .map(
          (a) => `<li><a href="${esc(a.u)}">
            <span class="lc-cat__link-title">${esc(a.t)}</span>
            <span class="lc-cat__link-meta">${esc(a.c)} · ${a.m} min</span>
          </a></li>`
        )
        .join('');
    };

    let timer;
    input.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => render(input.value.trim()), 120);
    });
  })();
</script>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* ---- Hero ---- */
  .lc-hero { background: var(--bg-pale-blue); padding-block: clamp(2rem, 1.2rem + 3vw, 3.5rem); }
  .lc-hero__inner {
    display: grid; gap: clamp(1.5rem, 1rem + 3vw, 3rem);
    grid-template-columns: minmax(0, 1fr); align-items: center;
  }
  @media (min-width: 56rem) {
    .lc-hero__inner { grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr); }
  }
  .lc-hero__title {
    font-size: clamp(2.5rem, 1.4rem + 4.4vw, 4rem);
    color: var(--navy); line-height: 1.04;
  }
  .lc-hero__lede {
    margin-top: 1.1rem; max-width: 34rem;
    font-size: var(--text-lead); line-height: 1.6; color: var(--text-body);
  }

  .lc-trust {
    display: flex; flex-wrap: wrap; gap: 1.75rem;
    list-style: none; padding: 0; margin: 1.75rem 0 0;
  }
  .lc-trust li { display: flex; align-items: center; gap: 0.55rem; }
  .lc-trust :global(svg) { width: 24px; height: 24px; color: var(--navy); flex: none; }
  .lc-trust span {
    font-size: var(--text-body-size); font-weight: 600; color: var(--navy);
    line-height: 1.3; white-space: pre-line;
  }

  /* ---- Hero collage: one tall image beside two stacked ---- */
  .lc-collage {
    display: grid; gap: 0.75rem;
    grid-template-columns: 1.9fr 1fr;
    grid-template-rows: repeat(2, 1fr);
    aspect-ratio: 16 / 9;
  }
  .lc-collage img {
    width: 100%; height: 100%; object-fit: cover;
    border-radius: 12px;
  }
  .lc-collage__main { grid-row: 1 / 3; }

  /* ---- Search ---- */
  .lc-body { padding-block: clamp(1.75rem, 1.2rem + 2vw, 2.75rem) var(--space-section); }
  .lc-search {
    position: relative; display: flex; align-items: center;
    margin-bottom: 2.5rem;
  }
  .lc-search :global(svg) {
    position: absolute; left: 1rem; width: 21px; height: 21px;
    color: var(--text-muted, #5A6B80); pointer-events: none;
  }
  .lc-search input {
    width: 100%; padding: 0.9rem 1rem 0.9rem 3.1rem;
    font: inherit; font-size: var(--text-body-size); color: var(--text-body);
    background: var(--white);
    border: 1px solid #DCE5F0; border-radius: 10px;
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .lc-search input::placeholder { color: #93A3B8; }
  .lc-search input:focus {
    outline: none; border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(0, 119, 190, 0.14);
  }

  /* ---- Featured ---- */
  .lc-featured__head {
    display: flex; flex-wrap: wrap; align-items: center;
    justify-content: space-between; gap: 0.75rem; margin-bottom: 1.1rem;
  }
  .lc-featured__head h2 {
    display: flex; align-items: center; gap: 0.55rem;
    font-size: var(--text-h3); color: var(--navy);
  }
  .lc-featured__head :global(svg) { width: 22px; height: 22px; color: var(--blue); }
  .lc-featured__all {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: var(--text-body-size); font-weight: 600;
  }
  .lc-featured__all :global(svg) { width: 18px; height: 18px; }

  .lc-featured__grid {
    display: grid; gap: 1rem; list-style: none; padding: 0; margin: 0 0 2.75rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 19.5rem), 1fr));
  }
  .lc-fcard {
    position: relative; display: flex; flex-direction: column; height: 100%;
    padding: 1.35rem 1.4rem; color: inherit;
    background: var(--white); border: 1px solid #E4EAF2; border-radius: 14px;
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease),
                transform var(--dur) var(--ease);
  }
  .lc-fcard:hover {
    border-color: var(--blue); transform: translateY(-2px);
    box-shadow: 0 14px 28px -16px rgba(8, 43, 89, 0.35); color: inherit;
  }
  .lc-fcard__icon {
    position: absolute; top: 1.2rem; right: 1.2rem;
    display: grid; place-items: center; width: 42px; height: 42px;
    border-radius: 50%; background: var(--bg-pale-blue);
  }
  .lc-fcard__icon :global(svg) { width: 20px; height: 20px; color: var(--blue); }
  .lc-fcard__cat {
    font-size: var(--text-body-size); font-weight: 700; letter-spacing: 0.05em;
    text-transform: uppercase; color: var(--blue);
  }
  .lc-fcard__title {
    margin-top: 0.5rem; padding-right: 3.4rem;
    font-family: var(--font-serif); font-weight: 600; font-size: var(--text-card-title);
    line-height: 1.25; color: var(--navy);
  }
  .lc-fcard__desc {
    margin-top: 0.6rem; font-size: var(--text-body-size); line-height: 1.55;
    color: var(--text-muted, #5A6B80);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .lc-fcard__meta {
    display: flex; align-items: center; gap: 0.45rem;
    margin-top: auto; padding-top: 0.9rem;
    font-size: var(--text-body-size); color: var(--text-muted, #5A6B80);
  }
  .lc-fcard__meta :global(svg) { width: 18px; height: 18px; }

  /* ---- Library accordion ---- */
  .lc-library {
    border: 1px solid #E4EAF2; border-radius: 14px; overflow: hidden;
    background: var(--white);
  }
  .lc-cat + .lc-cat { border-top: 1px solid #E4EAF2; }
  .lc-cat__row {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.15rem 1.4rem; cursor: pointer; list-style: none;
    transition: background var(--dur) var(--ease);
  }
  .lc-cat__row::-webkit-details-marker { display: none; }
  .lc-cat__row:hover { background: var(--bg-pale-blue); }
  .lc-cat__icon {
    display: grid; place-items: center; flex: none;
    width: 46px; height: 46px; border-radius: 12px; background: var(--bg-pale-blue);
  }
  .lc-cat__icon :global(svg) { width: 22px; height: 22px; color: var(--blue); }
  .lc-cat__text { flex: 1; min-width: 0; }
  .lc-cat__name {
    display: block; font-family: var(--font-serif); font-weight: 600;
    font-size: var(--text-card-title); color: var(--navy);
  }
  .lc-cat__desc {
    display: block; margin-top: 0.25rem; max-width: 48rem;
    font-size: var(--text-body-size); line-height: 1.5; color: var(--text-muted, #5A6B80);
  }
  .lc-cat__count {
    flex: none; font-size: var(--text-body-size); font-weight: 600; color: var(--navy);
  }
  .lc-cat__chev { flex: none; display: grid; place-items: center; }
  .lc-cat__chev :global(svg) {
    width: 21px; height: 21px; color: var(--text-muted, #5A6B80);
    transition: transform var(--dur) var(--ease);
  }
  .lc-cat[open] .lc-cat__chev :global(svg) { transform: rotate(180deg); }

  .lc-cat__list {
    list-style: none; padding: 0 1.4rem 1.1rem 5.4rem; margin: 0;
    display: grid; gap: 0.15rem;
  }
  .lc-cat__list a {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 1rem; padding: 0.5rem 0.6rem; margin-left: -0.6rem;
    border-radius: 8px; color: var(--text-body);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .lc-cat__list a:hover { background: var(--bg-pale-blue); color: var(--blue); }
  .lc-cat__link-title { font-size: var(--text-body-size); line-height: 1.45; }
  .lc-cat__link-meta {
    flex: none; font-size: var(--text-body-size); color: var(--text-muted, #5A6B80);
  }
  @media (max-width: 40rem) {
    .lc-cat__desc, .lc-cat__count { display: none; }
    .lc-cat__list { padding-left: 1.4rem; }
  }

  /* ---- Search results ---- */
  .lc-results__title { font-size: var(--text-h3); color: var(--navy); margin-bottom: 0.9rem; }
  .lc-results__list {
    list-style: none; padding: 0.4rem; margin: 0;
    border: 1px solid #E4EAF2; border-radius: 14px; background: var(--white);
  }
  .lc-results__list a {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 1rem; padding: 0.7rem 0.9rem; border-radius: 8px; color: var(--text-body);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .lc-results__list a:hover { background: var(--bg-pale-blue); color: var(--blue); }

  /* ---- Closing CTA ---- */
  .lc-cta {
    display: flex; flex-wrap: wrap; align-items: center; gap: 1.25rem;
    margin-top: clamp(2rem, 1.5rem + 2vw, 3rem);
    padding: clamp(1.4rem, 1rem + 1.5vw, 2rem);
    background: var(--bg-pale-blue); border-radius: 14px;
  }
  .lc-cta__mark { width: 56px; height: auto; flex: none; }
  .lc-cta__text { flex: 1 1 22rem; }
  .lc-cta h2 { font-size: var(--text-h3); color: var(--navy); }
  .lc-cta p {
    margin-top: 0.45rem; font-size: var(--text-body-size); line-height: 1.55;
    max-width: 38rem; color: var(--text-muted, #5A6B80);
  }
  .lc-cta__btn { flex: none; }

  .lc-disclaimer {
    margin-top: 1.5rem; text-align: center;
    font-size: var(--text-body-size); line-height: 1.6; color: var(--text-muted, #5A6B80);
  }
</style>
